---
interface Props {
  status: string;
}

const { status } = Astro.props;

const styles: Record<string, string> = {
  confirmed_active: 'bg-emerald-50 text-emerald-700 ring-emerald-600/20 dark:bg-emerald-950 dark:text-emerald-300',
  inferred: 'bg-amber-50 text-amber-700 ring-amber-600/20 dark:bg-amber-950 dark:text-amber-300',
  deprecated: 'bg-red-50 text-red-700 ring-red-600/20 dark:bg-red-950 dark:text-red-300',
  unknown: 'bg-[var(--surface-alt)] text-[var(--text-secondary)] ring-[var(--border)]',
};

const labels: Record<string, string> = {
  confirmed_active: 'Active',
  inferred: 'Inferred',
  deprecated: 'Deprecated',
  unknown: 'Unknown',
};

const tooltips: Record<string, string> = {
  confirmed_active: 'Directly verified through system access or vendor confirmation',
  inferred: 'Detected from code or documentation but not directly confirmed',
  deprecated: 'No longer actively used or supported',
  unknown: 'Status has not been determined yet',
};

const style = styles[status] ?? styles['unknown'];
const label = labels[status] ?? status;
const tooltip = tooltips[status] ?? '';
---

<span class:list={['inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ring-1 ring-inset', style]} title={tooltip}>
  {label}
</span>
