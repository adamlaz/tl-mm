---
interface Props {
  status: string;
}

const { status } = Astro.props;

const styles: Record<string, string> = {
  confirmed_active: 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
  inferred: 'bg-amber-50 text-amber-700 ring-amber-600/20',
  deprecated: 'bg-red-50 text-red-700 ring-red-600/20',
  unknown: 'bg-slate-50 text-slate-600 ring-slate-500/20',
};

const labels: Record<string, string> = {
  confirmed_active: 'Active',
  inferred: 'Inferred',
  deprecated: 'Deprecated',
  unknown: 'Unknown',
};

const style = styles[status] ?? styles['unknown'];
const label = labels[status] ?? status;
---

<span class:list={['inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ring-1 ring-inset', style]}>
  {label}
</span>
