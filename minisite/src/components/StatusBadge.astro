---
interface Props {
  status: string;
}

const { status } = Astro.props;

const colorMap: Record<string, { color: string; bg: string }> = {
  confirmed_active: { color: 'var(--status-green)', bg: 'var(--status-green-bg)' },
  inferred: { color: 'var(--status-amber)', bg: 'var(--status-amber-bg)' },
  deprecated: { color: 'var(--status-red)', bg: 'var(--status-red-bg)' },
  unknown: { color: 'var(--text-secondary)', bg: 'var(--surface-alt)' },
};

const labels: Record<string, string> = {
  confirmed_active: 'Active',
  inferred: 'Inferred',
  deprecated: 'Deprecated',
  unknown: 'Unknown',
};

const tooltips: Record<string, string> = {
  confirmed_active: 'Directly verified through system access or vendor confirmation',
  inferred: 'Detected from code or documentation but not directly confirmed',
  deprecated: 'No longer actively used or supported',
  unknown: 'Status has not been determined yet',
};

const colors = colorMap[status] ?? colorMap['unknown'];
const label = labels[status] ?? status;
const tooltip = tooltips[status] ?? '';
---

<span
  class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ring-1 ring-inset"
  style={`color: ${colors.color}; background: ${colors.bg}; --tw-ring-color: ${colors.color};`}
  title={tooltip}
>
  {label}
</span>
