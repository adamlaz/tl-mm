---
interface Props {
  label: string;
  value: string | number;
  subtitle?: string;
}

const { label, value, subtitle } = Astro.props;
---

<div class="bg-white rounded-xl border border-slate-200 p-5 flex flex-col gap-1">
  <dt class="text-xs font-medium uppercase tracking-wider text-slate-400">{label}</dt>
  <dd class="text-2xl font-semibold text-slate-900 font-mono tabular-nums">{value}</dd>
  {subtitle && <p class="text-xs text-slate-500 mt-0.5">{subtitle}</p>}
</div>
