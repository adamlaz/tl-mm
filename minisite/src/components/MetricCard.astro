---
interface Props {
  label: string;
  value: string | number;
  subtitle?: string;
}

const { label, value, subtitle } = Astro.props;
---

<div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5">
  <dl class="flex flex-col gap-1">
    <dt class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)]">{label}</dt>
    <dd class="text-2xl font-semibold text-[var(--text)] font-mono tabular-nums">{value}</dd>
    {subtitle && <dd class="text-xs text-[var(--text-secondary)] mt-0.5">{subtitle}</dd>}
  </dl>
</div>
