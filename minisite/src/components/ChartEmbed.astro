---
import { readFileSync, existsSync } from 'node:fs';
import { resolve } from 'node:path';

interface Props {
  slug: string;
  title: string;
  description?: string;
  caption?: string;
  source?: string;
  height?: string;
  interactive?: boolean;
}

const { slug, title, description, caption, source, height, interactive = true } = Astro.props;
const chartPath = resolve('../analysis/charts', `${slug}.json`);
const hasData = existsSync(chartPath);
const chartData = hasData ? readFileSync(chartPath, 'utf-8') : '';

let metaSource = '';
if (hasData && !source) {
  try {
    const parsed = JSON.parse(chartData);
    metaSource = parsed._meta?.source ?? '';
  } catch {}
}
const displaySource = source || metaSource;

const chartClass = height
  ? 'w-full rounded-b-xl'
  : 'aspect-[16/10] w-full rounded-b-xl';
const chartStyle = height ? `min-height:${height}` : undefined;
---

<div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] overflow-hidden relative" data-chart-wrap>
  <div class="px-5 pt-4 pb-2 flex items-center justify-between">
    <div>
      <h3 class="text-sm font-semibold text-[var(--text)]">{title}</h3>
      {description && (
        <p class="text-xs text-[var(--text-secondary)] mt-0.5">{description}</p>
      )}
    </div>
    {interactive && (
      <button
        type="button"
        class="p-1.5 rounded-md text-[var(--text-muted)] hover:text-[var(--text)] hover:bg-[var(--surface-alt)] transition-colors"
        data-fullscreen-toggle
        title="Toggle fullscreen"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3" />
        </svg>
      </button>
    )}
  </div>
  {hasData ? (
    <div class={chartClass} style={chartStyle} data-echarts>
      <script type="application/json" set:html={chartData} />
    </div>
  ) : (
    <div class={chartClass} style={chartStyle}>
      <div class="h-full flex items-center justify-center bg-[var(--surface-alt)] rounded-b-xl">
        <p class="text-xs text-[var(--text-muted)]">Chart data not generated yet</p>
      </div>
    </div>
  )}
  {(caption || displaySource) && (
    <div class="px-5 pb-4 pt-2">
      {caption && (
        <p class="text-xs text-[var(--text-secondary)] leading-relaxed max-w-prose">{caption}</p>
      )}
      {displaySource && (
        <p class="text-[10px] text-[var(--text-muted)] mt-1">{displaySource}</p>
      )}
    </div>
  )}
  {interactive && (
    <span class="absolute bottom-2 right-3 text-[10px] text-[var(--text-muted)] opacity-60 pointer-events-none select-none">
      Scroll to zoom &middot; Drag to pan
    </span>
  )}
</div>

{interactive && (
  <script is:inline>
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-fullscreen-toggle]');
      if (!btn) return;
      var wrap = btn.closest('[data-chart-wrap]');
      if (!wrap) return;
      if (document.fullscreenElement === wrap) {
        document.exitFullscreen();
      } else {
        wrap.requestFullscreen().then(function () {
          wrap.style.background = 'var(--surface)';
          var chart = wrap.querySelector('[data-echarts]');
          if (chart && chart.__echart) chart.__echart.resize();
        });
      }
    });
    document.addEventListener('fullscreenchange', function () {
      if (!document.fullscreenElement) {
        document.querySelectorAll('[data-chart-wrap]').forEach(function (w) {
          w.style.background = '';
          var chart = w.querySelector('[data-echarts]');
          if (chart && chart.__echart) chart.__echart.resize();
        });
      }
    });
  </script>
)}
