---
interface Props {
  slug: string;
  title: string;
  description?: string;
}

const { slug, title, description } = Astro.props;
---

<div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] overflow-hidden">
  <div class="px-5 pt-4 pb-2">
    <h3 class="text-sm font-semibold text-[var(--text)]">{title}</h3>
    {description && <p class="text-xs text-[var(--text-secondary)] mt-0.5">{description}</p>}
  </div>
  <div class="aspect-[16/10] w-full">
    <iframe src={`/chart-assets/${slug}.html`} title={title} class="w-full h-full border-0" loading="lazy" />
  </div>
</div>
