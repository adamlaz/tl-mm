---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

type NavItem = { href: string; label: string; icon: string };
type NavGroup = { heading: string; items: NavItem[] };

const groups: NavGroup[] = [
  {
    heading: 'Overview',
    items: [
      { href: '/', label: 'Dashboard', icon: 'grid' },
      { href: '/engagement', label: 'Engagement', icon: 'compass' },
    ],
  },
  {
    heading: 'Systems',
    items: [
      { href: '/infrastructure', label: 'Infrastructure', icon: 'cloud' },
      { href: '/engineering', label: 'Engineering', icon: 'code' },
      { href: '/delivery', label: 'Delivery', icon: 'activity' },
      { href: '/documentation', label: 'Documentation', icon: 'file-text' },
    ],
  },
  {
    heading: 'Cross-Cutting',
    items: [
      { href: '/people', label: 'People & Org', icon: 'users' },
      { href: '/tooling', label: 'Tooling', icon: 'tool' },
      { href: '/surveys', label: 'Surveys', icon: 'clipboard' },
    ],
  },
  {
    heading: 'Reference',
    items: [{ href: '/charts', label: 'Charts', icon: 'bar-chart' }],
  },
];

const allLinks = groups.flatMap((g) => g.items);

const mobileLinks = [
  { href: '/', label: 'Home', icon: 'grid' },
  { href: '/infrastructure', label: 'Infra', icon: 'cloud' },
  { href: '/engineering', label: 'Eng', icon: 'code' },
  { href: '/delivery', label: 'Delivery', icon: 'activity' },
  { href: '/people', label: 'People', icon: 'users' },
  { href: '/charts', label: 'Charts', icon: 'bar-chart' },
];

const iconPaths: Record<string, string> = {
  compass:
    'M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0 0l3.5-6.5L22 12l-6.5-3.5L12 2 8.5 8.5 2 12l6.5 3.5L12 22z',
  users:
    'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  grid: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z',
  cloud: 'M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z',
  code: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  activity: 'M22 12h-4l-3 9L9 3l-3 9H2',
  'file-text': 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
  clipboard:
    'M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2M9 2h6a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z',
  tool: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
  'bar-chart': 'M12 20V10M18 20V4M6 20v-4',
};

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
}
---

<nav
  class="hidden lg:flex flex-col w-56 border-r border-[var(--border)] bg-[var(--surface)] min-h-screen pt-6 pb-8 px-3 flex-shrink-0"
>
  <div class="px-3 mb-6">
    <span class="text-xs font-bold text-[var(--text)]">Mad Mobile</span>
    <span class="block text-[10px] text-[var(--text-muted)] mt-0.5">Tech & Ops Review</span>
  </div>
  <div class="space-y-5 flex-1">
    {groups.map(({ heading, items }) => (
      <div>
        <span class="px-3 text-[10px] font-semibold uppercase tracking-widest text-[var(--text-muted)]">
          {heading}
        </span>
        <ul class="mt-1.5 space-y-0.5">
          {items.map(({ href, label, icon }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                  isActive(href)
                    ? 'bg-[var(--accent-subtle)] text-[var(--accent)]'
                    : 'text-[var(--text-secondary)] hover:bg-[var(--surface-alt)] hover:text-[var(--text)]',
                ]}
              >
                <svg
                  class="w-4 h-4 flex-shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d={iconPaths[icon]} />
                </svg>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</nav>

<div class="lg:hidden fixed bottom-0 left-0 right-0 bg-[var(--surface)] border-t border-[var(--border)] z-50 px-2 py-1">
  <div class="flex justify-around">
    {mobileLinks.map(({ href, label, icon }) => (
      <a
        href={href}
        class:list={[
          'flex flex-col items-center gap-0.5 px-2 py-1.5 text-[10px] font-medium rounded transition-colors',
          isActive(href) ? 'text-[var(--accent)]' : 'text-[var(--text-muted)]',
        ]}
      >
        <svg
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d={iconPaths[icon]} />
        </svg>
        {label}
      </a>
    ))}
  </div>
</div>
