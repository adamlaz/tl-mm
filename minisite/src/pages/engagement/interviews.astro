---
export const prerender = true;

import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import MetricCard from '../../components/MetricCard.astro';
import TabulatorGrid from '../../components/TabulatorGrid.astro';

const raw = readFileSync(resolve(process.cwd(), '../interview_schedule.json'), 'utf-8');
const schedule = JSON.parse(raw);
const sessions: any[] = schedule.sessions;

const monday = sessions.filter((s: any) => s.day === 'Monday');
const tuesday = sessions.filter((s: any) => s.day === 'Tuesday');
const wednesday = sessions.filter((s: any) => s.day === 'Wednesday');

function toRows(list: any[]) {
  return list.map((s: any) => ({
    time: s.proposed_time,
    name: s.name,
    title: s.title,
    duration: s.format === 'video' ? `${s.duration_min} min (video)` : `${s.duration_min} min`,
    focus: s.focus,
    tier: s.tier === 1 ? 'Tier 1' : 'Tier 2',
  }));
}

const scheduleColumns = [
  { key: 'time', label: 'Time', sortable: false, minWidth: '80px' },
  { key: 'name', label: 'Name', type: 'avatar' as const, sortable: false },
  { key: 'title', label: 'Title', type: 'badge' as const, sortable: false },
  { key: 'duration', label: 'Duration', sortable: false, minWidth: '80px' },
  { key: 'focus', label: 'Focus', sortable: false },
  { key: 'tier', label: 'Tier', type: 'badge' as const, sortable: false, badgeMap: { 'Tier 1': 'green', 'Tier 2': 'amber' } },
];

const timeToMin = (t: string) => {
  const [h, m] = t.split(':').map(Number);
  return h * 60 + m;
};

const rhythmBlocks = [
  { day: 0, start: '8:00', end: '8:30', label: 'Don sync', cat: 0 },
  { day: 0, start: '8:30', end: '12:00', label: 'Interviews (4)', cat: 1 },
  { day: 0, start: '12:00', end: '13:00', label: 'Lunch', cat: 2 },
  { day: 0, start: '13:00', end: '16:00', label: 'Interviews (3)', cat: 1 },
  { day: 0, start: '16:00', end: '16:30', label: 'Synthesis', cat: 3 },
  { day: 0, start: '16:30', end: '17:00', label: 'Don debrief', cat: 0 },
  { day: 1, start: '8:00', end: '8:30', label: 'Don sync', cat: 0 },
  { day: 1, start: '8:30', end: '12:00', label: 'Interviews (4)', cat: 1 },
  { day: 1, start: '12:00', end: '13:00', label: 'Lunch', cat: 2 },
  { day: 1, start: '13:00', end: '15:45', label: 'Interviews (4)', cat: 1 },
  { day: 1, start: '16:00', end: '17:00', label: 'Synthesis', cat: 3 },
  { day: 1, start: '17:00', end: '17:30', label: 'Don debrief', cat: 0 },
  { day: 2, start: '8:00', end: '8:30', label: 'Don sync', cat: 0 },
  { day: 2, start: '8:30', end: '12:00', label: 'Interviews (5)', cat: 1 },
  { day: 2, start: '12:00', end: '13:00', label: 'Lunch', cat: 2 },
  { day: 2, start: '13:00', end: '15:00', label: 'Interviews (3)', cat: 1 },
  { day: 2, start: '15:00', end: '16:00', label: 'Final synthesis', cat: 3 },
  { day: 2, start: '16:00', end: '16:30', label: 'Don debrief', cat: 0 },
];

const chartData = JSON.stringify(rhythmBlocks.map(b => ({
  value: [b.day, timeToMin(b.start), timeToMin(b.end), b.label, b.cat],
})));

const catColors = ['#8A8070', '#4A5FC4', '#B07A4A', '#6B82A0'];
const catNames = ['Don sync / debrief', 'Interviews', 'Lunch', 'Synthesis'];
---

<BaseLayout title="Interview Schedule">
  <SectionHeader
    eyebrow="ONSITE INTERVIEW PLAN"
    title="April 13–15, Tampa HQ"
    description="23 sessions across 3 days. All MUST sessions booked. All TBD slots confirmed by Chathura. Rajik Gunatilaka (W2) departed — SL replacement needed. Jeremy Diggins (W4) flagged as potentially unavailable (client onsite)."
  />

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Sessions" value="23" subtitle="3 days onsite" />
    <MetricCard label="Tier 1" value="16" subtitle="Must happen face-to-face" />
    <MetricCard label="Tier 2" value="7" subtitle="Can go async/video if needed" />
    <MetricCard label="Cases to Trace" value="5" subtitle="End-to-end process validation" />
  </dl>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Daily Rhythm</h2>
    <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] overflow-hidden">
      <div style="height:180px;width:100%;" id="rhythm-chart"></div>
      <div class="px-5 py-3 border-t border-[var(--border)] flex flex-wrap gap-4">
        {catNames.map((name, i) => (
          <div class="flex items-center gap-1.5 text-xs text-[var(--text-secondary)]">
            <span class="w-3 h-3 rounded-sm shrink-0" style={`background: ${catColors[i]};`}></span>
            {name}
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Monday — Leadership & Strategy</h2>
    <TabulatorGrid columns={scheduleColumns} rows={toRows(monday)} />
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Tuesday — Engineering Deep Dive</h2>
    <TabulatorGrid columns={scheduleColumns} rows={toRows(tuesday)} />
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Wednesday — Validation & Gaps</h2>
    <TabulatorGrid columns={scheduleColumns} rows={toRows(wednesday)} />
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Scope Discipline</h2>
    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-xl p-5">
      <h3 class="text-sm font-semibold text-[var(--text)] mb-3">What We Will NOT Attempt Onsite</h3>
      <ul class="space-y-1.5 text-[13px] text-[var(--text-secondary)] leading-relaxed">
        <li class="flex items-start gap-2"><span class="text-[var(--text-muted)] mt-0.5">•</span>Exhaustive code review</li>
        <li class="flex items-start gap-2"><span class="text-[var(--text-muted)] mt-0.5">•</span>Contract-level vendor/pricing analysis</li>
        <li class="flex items-start gap-2"><span class="text-[var(--text-muted)] mt-0.5">•</span>Detailed architecture documentation (C4 Level 3+)</li>
        <li class="flex items-start gap-2"><span class="text-[var(--text-muted)] mt-0.5">•</span>Historical blame analysis</li>
        <li class="flex items-start gap-2"><span class="text-[var(--text-muted)] mt-0.5">•</span>Individual performance assessment</li>
      </ul>
    </div>
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Cases to Trace</h2>
    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-xl p-5">
      <ol class="space-y-2 text-[13px] text-[var(--text-secondary)] leading-relaxed list-none">
        <li class="flex items-start gap-3">
          <span class="shrink-0 w-5 h-5 rounded-full bg-[var(--accent-subtle)] text-[var(--accent)] text-xs font-bold flex items-center justify-center">1</span>
          One CAKE payment processing outage — detection through resolution
        </li>
        <li class="flex items-start gap-3">
          <span class="shrink-0 w-5 h-5 rounded-full bg-[var(--accent-subtle)] text-[var(--accent)] text-xs font-bold flex items-center justify-center">2</span>
          One recent customer escalation — complaint through organizational response
        </li>
        <li class="flex items-start gap-3">
          <span class="shrink-0 w-5 h-5 rounded-full bg-[var(--accent-subtle)] text-[var(--accent)] text-xs font-bold flex items-center justify-center">3</span>
          One delayed strategic initiative — structural factors behind the slip
        </li>
        <li class="flex items-start gap-3">
          <span class="shrink-0 w-5 h-5 rounded-full bg-[var(--accent-subtle)] text-[var(--accent)] text-xs font-bold flex items-center justify-center">4</span>
          One mid-sprint priority change — who requested it, downstream impact
        </li>
        <li class="flex items-start gap-3">
          <span class="shrink-0 w-5 h-5 rounded-full bg-[var(--accent-subtle)] text-[var(--accent)] text-xs font-bold flex items-center justify-center">5</span>
          One cross-functional success story — what conditions made it work
        </li>
      </ol>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ chartData }}>
(function() {
  var COLORS = ['#8A8070', '#4A5FC4', '#B07A4A', '#6B82A0'];
  var DAYS = ['Monday', 'Tuesday', 'Wednesday'];
  var data = JSON.parse(chartData);

  function fmtTime(m) { return Math.floor(m/60) + ':' + String(m%60).padStart(2,'0'); }

  function initRhythm() {
    if (typeof echarts === 'undefined') { setTimeout(initRhythm, 100); return; }
    var el = document.getElementById('rhythm-chart');
    if (!el) return;
    if (el.__rhythmChart) { try { el.__rhythmChart.dispose(); } catch(e){} }

    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    var chart = echarts.init(el, isDark ? 'tl-dark' : null, { renderer: 'canvas' });
    el.__rhythmChart = chart;

    chart.setOption({
      tooltip: {
        formatter: function(p) {
          var d = p.value || (p.data && p.data.value);
          if (!d) return '';
          return '<b>' + d[3] + '</b><br/>' + DAYS[d[0]] + ': ' + fmtTime(d[1]) + ' – ' + fmtTime(d[2]);
        },
      },
      grid: { left: 90, right: 20, top: 10, bottom: 30 },
      xAxis: {
        type: 'value',
        min: 480,
        max: 1050,
        axisLabel: { formatter: function(v) { return fmtTime(v); } },
        splitLine: { show: false },
      },
      yAxis: {
        type: 'category',
        data: DAYS,
        inverse: true,
        axisTick: { show: false },
      },
      series: [{
        type: 'custom',
        renderItem: function(params, api) {
          var dayIdx = api.value(0);
          var startVal = api.value(1);
          var endVal = api.value(2);
          var catIdx = api.value(4);
          var start = api.coord([startVal, dayIdx]);
          var endPt = api.coord([endVal, dayIdx]);
          var bandWidth = api.size([0, 1])[1] * 0.6;
          return {
            type: 'rect',
            shape: { x: start[0], y: start[1] - bandWidth / 2, width: endPt[0] - start[0], height: bandWidth, r: 3 },
            style: api.style({ fill: COLORS[catIdx] || COLORS[0], opacity: 0.85 }),
          };
        },
        encode: { x: [1, 2], y: 0 },
        data: data,
      }],
    });
  }

  function onResize() {
    var el = document.getElementById('rhythm-chart');
    if (el && el.__rhythmChart) el.__rhythmChart.resize();
  }

  var resizeTimer;
  window.addEventListener('resize', function() { clearTimeout(resizeTimer); resizeTimer = setTimeout(onResize, 100); });

  new MutationObserver(function() {
    initRhythm();
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRhythm);
  } else {
    initRhythm();
  }
  document.addEventListener('astro:page-load', initRhythm);
})();
</script>
