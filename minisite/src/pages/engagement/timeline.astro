---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import MetricCard from '../../components/MetricCard.astro';
import MilestoneStep from '../../components/MilestoneStep.astro';
import TabulatorGrid from '../../components/TabulatorGrid.astro';

const openItems = [
  { item: 'Chathura survey email — only 4 of 5 surveys (AI Tooling link sent)', owner: 'Adam → Chathura', deadline: 'Apr 6', status: 'In Progress', category: 'Coordination' },
  { item: 'Enterprise Solutions org detail (Zubair — 58 people, no names)', owner: 'Adam → Chathura', deadline: 'Apr 6', status: 'Blocked', category: 'Data Gap' },
  { item: 'Jira incident query (2024–2026 gap in RCA timeline)', owner: 'Adam', deadline: 'Apr 6', status: 'Pending', category: 'Data Gap' },
  { item: 'Root Cause Category field #2 (customfield_10590)', owner: 'Adam', deadline: 'Apr 6', status: 'Pending', category: 'Data Gap' },
  { item: 'CloudTrail access escalation (deployment frequency)', owner: 'Adam → Ana', deadline: 'Apr 6', status: 'Pending', category: 'Access' },
  { item: 'Grafana viewer access', owner: 'Ana → Matias', deadline: 'Apr 6', status: 'Confirmed', category: 'Access' },
  { item: 'Branch protection validation (project-level vs repo-level)', owner: 'Adam', deadline: 'Apr 7', status: 'Pending', category: 'Data Gap' },
  { item: 'L&D reporting discrepancy (Dulanjan vs Shatney)', owner: 'Adam', deadline: 'Onsite', status: 'Pending', category: 'Clarification' },
  { item: 'Andy Honnold dual-report (Garcia vs Akshay)', owner: 'Adam', deadline: 'Onsite', status: 'Pending', category: 'Clarification' },
  { item: 'Ana + Chathura coordination update — all requests/next steps', owner: 'Adam', deadline: 'Apr 5 evening', status: 'In Progress', category: 'Coordination' },
  { item: 'All 5 surveys built in Microsoft Forms', owner: 'Adam', deadline: 'Apr 5', status: 'Complete', category: 'Coordination' },
  { item: 'Finalize interview schedule grid for Ana', owner: 'Adam', deadline: 'Apr 6', status: 'Pending', category: 'Coordination' },
  { item: 'Microsoft 365 / Azure AD access (Graph API)', owner: 'Adam → Ana/IT', deadline: 'Apr 6', status: 'Pending', category: 'Access' },
  { item: 'Vendor/SaaS spend data from finance', owner: 'Adam → Ana', deadline: 'Apr 10', status: 'Pending', category: 'Data Gap' },
];

const accessRows = [
  { system: 'Mad Mobile Email', status: 'Active', confirmed: 'Mar 28', notes: 'adam.lazarus@madmobile.com' },
  { system: 'Microsoft Teams', status: 'Active', confirmed: 'Mar 28', notes: 'Connected to Global Hub' },
  { system: 'Bitbucket (4 orgs)', status: 'Active', confirmed: 'Apr 1', notes: 'MadMobile, Sysco Labs, Mad Payments, Sysco Labs Conf' },
  { system: 'Jira / Confluence', status: 'Active', confirmed: 'Apr 1', notes: 'API tokens working' },
  { system: 'AWS SSO (18 accounts)', status: 'Active', confirmed: 'Apr 2', notes: 'Global-Audit-RO role, CLI configured' },
  { system: 'Grafana', status: 'Pending', confirmed: 'Apr 6 (confirmed)', notes: 'Matias off for holiday weekend — Monday access' },
  { system: 'CloudWatch Alarms', status: 'Pending', confirmed: '—', notes: 'cloudwatch:DescribeAlarms not in audit role — escalation needed' },
];

const openItemColumns = [
  { key: 'item', label: 'Item', sortable: true, minWidth: '280px' },
  { key: 'owner', label: 'Owner', type: 'badge' as const, sortable: true },
  { key: 'deadline', label: 'Deadline', sortable: true },
  { key: 'status', label: 'Status', type: 'badge' as const, sortable: true, filterable: true, badgeMap: { Confirmed: 'green', 'In Progress': 'amber', Pending: 'muted', Blocked: 'red' } },
  { key: 'category', label: 'Category', type: 'badge' as const, sortable: true, filterable: true },
];

const accessColumns = [
  { key: 'system', label: 'System', sortable: true },
  { key: 'status', label: 'Status', type: 'badge' as const, sortable: true, badgeMap: { Active: 'green', Pending: 'amber' } },
  { key: 'confirmed', label: 'Confirmed', sortable: true },
  { key: 'notes', label: 'Notes' },
];
---

<BaseLayout title="Timeline & Status">
  <SectionHeader
    eyebrow="TIMELINE & STATUS"
    title="Engagement Timeline"
    description="Pre-work through deliverables. Every milestone has an owner, a date, and an explicit status."
  />

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Pre-Work" value="7 rounds" subtitle="V1–V7 complete" />
    <MetricCard label="Data Artifacts" value="31 charts, 17 CSVs" subtitle="94 Confluence pages extracted" />
    <MetricCard label="Access" value="5 of 7" subtitle="Grafana + CloudWatch pending" />
    <MetricCard label="Surveys" value="5 of 5 built" subtitle="All links ready for Apr 6 deploy" />
  </dl>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Pre-Work Milestones</h2>
    <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5">
      <MilestoneStep
        date="Mar 24–28"
        title="Don briefs Chathura and Kennedy"
        detail="Coordination brief and NotebookLM materials shared with MM leadership."
        status="complete"
      />
      <MilestoneStep
        date="Mar 28–Apr 1"
        title="System access provisioned"
        detail="MM email, Teams, Bitbucket (4 orgs), Jira/Confluence, AWS SSO (18 accounts) all active."
        status="complete"
      />
      <MilestoneStep
        date="Apr 1–3"
        title="V1–V6 system reconnaissance"
        detail="Automated scans across all platforms. 29+ charts, 168-user audit, engagement minisite built."
        status="complete"
      />
      <MilestoneStep
        date="Apr 3"
        title="April 3 reorg mapped"
        detail="Siegel/Lodes exits, Chathura promoted to CDO, Kennedy narrowed. Org chart remapped. Survey 5 designed. CDO org chart received from Chathura."
        status="complete"
      />
      <MilestoneStep
        date="Apr 3–4"
        title="V7 deep collection"
        detail="25 enrichment items: epic completion (27.7%), incident timeline (50 RCAs), reviewer network (1,464 edges), pipeline reliability (60.7%), ECS health checks (90% missing)."
        status="complete"
      />
      <MilestoneStep
        date="Apr 5"
        title="Don touchbase — reorg alignment"
        detail="Reorg-specific questions: Kennedy's future, Strainick appointment, board deck transparency. V7 findings briefed."
        status="active"
      />
      <MilestoneStep
        date="Apr 5 evening"
        title="Ana + Chathura coordination update"
        detail="Send updated requests, next steps, and pre-onsite logistics. Confirm Grafana Monday, interview schedule grid, Survey 5 inclusion."
        status="active"
      />
      <MilestoneStep
        date="Apr 6"
        title="Surveys go live + Grafana access"
        detail="Chathura sends survey intro as CDO. 5 surveys via Microsoft Forms. Grafana viewer access confirmed for Monday. Pre-read package from Ana."
        status="upcoming"
      />
      <MilestoneStep
        date="Apr 6–8"
        title="Don Sessions 2 and 3"
        detail="Session 2: political landscape and hypotheses. Session 3: pre-onsite briefing with synthesized findings."
        status="upcoming"
      />
      <MilestoneStep
        date="Apr 10–11"
        title="Survey close and final prep"
        detail="Survey analysis same day. Final hypothesis scorecard update. Print onsite materials. Pre-onsite briefing with Don."
        status="upcoming"
      />
      <MilestoneStep
        date="Apr 13–15"
        title="Onsite diagnostic sprint"
        detail="Tampa HQ. 18–21 interviews, architecture walkthroughs, value stream mapping, real case tracing."
        status="upcoming"
      />
      <MilestoneStep
        date="Apr 16–25"
        title="Deliverables"
        detail="CEO operating brief, friction register, hypothesis scorecard, 30/60/90 plan, board-ready presentation, survey package."
        status="upcoming"
        last={true}
      />
    </div>
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Open Items</h2>
    <TabulatorGrid
      columns={openItemColumns}
      rows={openItems}
      searchable={true}
    />
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Access Status</h2>
    <TabulatorGrid
      columns={accessColumns}
      rows={accessRows}
    />
  </div>
</BaseLayout>
