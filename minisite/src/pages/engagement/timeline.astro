---
export const prerender = true;

import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import MetricCard from '../../components/MetricCard.astro';
import MilestoneStep from '../../components/MilestoneStep.astro';
import TabulatorGrid from '../../components/TabulatorGrid.astro';

const scheduleRaw = readFileSync(resolve(process.cwd(), '../interview_schedule.json'), 'utf-8');
const interviewSchedule = JSON.parse(scheduleRaw);
const scheduleSessions: any[] = interviewSchedule.sessions;
const scheduleSessionTotal = scheduleSessions.length;
const scheduleInterviewTotal = scheduleSessions.filter(
  (s: any) => s.format !== 'debrief' && s.format !== 'group-informal',
).length;
const onsiteSessionsSummary = `${scheduleSessionTotal} sessions (${scheduleInterviewTotal} interviews)`;

const openItems = [
  { item: 'Scan neo-workspace repo (Winmark/Neo codebase) — file tree, languages, architecture, CI/CD', owner: 'Adam', deadline: 'Apr 7', status: 'In Progress', category: 'Data Gap' },
  { item: 'Scan Winmark Jira board (WM project, board 1712) — epics, velocity, team', owner: 'Adam', deadline: 'Apr 7', status: 'In Progress', category: 'Data Gap' },
  { item: 'W2 / Sri Lanka slot — Wenushka Dikowita confirmed (SL coverage)', owner: 'Adam', deadline: 'Apr 8', status: 'Complete', category: 'Coordination' },
  { item: 'PREFERRED interview sessions — all confirmed', owner: 'Ana', deadline: 'Apr 8', status: 'Complete', category: 'Coordination' },
  { item: 'Survey response rate monitoring (38 of 57, 67%)', owner: 'Adam', deadline: 'Apr 10', status: 'Complete', category: 'Coordination' },
  { item: 'Enterprise Solutions org detail (Zubair — 58 people)', owner: 'Chathura', deadline: 'Apr 9', status: 'In Progress', category: 'Data Gap' },
  { item: 'Incident/RCA docs for last 90 days — 5 executive RCAs received', owner: 'Chathura', deadline: 'Apr 9', status: 'Complete', category: 'Data Gap' },
  { item: 'Grafana — 3 instances confirmed (CAKE, Retail, Payments)', owner: 'Ana → Matias', deadline: 'Apr 7', status: 'Complete', category: 'Access' },
  { item: 'Microsoft Graph API — access confirmed and working', owner: 'Ana → IT', deadline: 'Apr 7', status: 'Complete', category: 'Access' },
  { item: 'CloudTrail LookupEvents — Chathura approved, waiting on IT to add to role', owner: 'IT', deadline: 'Apr 7', status: 'Confirmed', category: 'Access' },
  { item: 'Vendor/SaaS spend — 2 Amex spreadsheets received, Bill.com + AWS Marketplace pending', owner: 'Ana', deadline: 'Apr 10', status: 'In Progress', category: 'Data Gap' },
  { item: 'Jira incident query (2024–2026 gap in RCA timeline)', owner: 'Adam', deadline: 'Apr 7', status: 'Pending', category: 'Data Gap' },
  { item: 'Root Cause Category field #2 (customfield_10590)', owner: 'Adam', deadline: 'Apr 7', status: 'Pending', category: 'Data Gap' },
  { item: 'Branch protection validation (project-level vs repo-level)', owner: 'Adam', deadline: 'Apr 7', status: 'Pending', category: 'Data Gap' },
  { item: 'Jeremy Diggins availability — confirmed for W4 Wednesday', owner: 'Adam', deadline: 'Apr 8', status: 'Complete', category: 'Coordination' },
  { item: 'L&D reporting discrepancy (Dulanjan vs Shatney)', owner: 'Adam', deadline: 'Onsite', status: 'Pending', category: 'Clarification' },
  { item: 'Andy Honnold dual-report (Garcia vs Akshay)', owner: 'Adam', deadline: 'Onsite', status: 'Pending', category: 'Clarification' },
  { item: 'MUST interview sessions booked by Ana', owner: 'Ana', deadline: 'Apr 6', status: 'Complete', category: 'Coordination' },
  { item: 'All 6 TBD interview slots confirmed by Chathura (Baine, Oliver, Budd, Akula, Renard, Lee)', owner: 'Chathura', deadline: 'Apr 7', status: 'Complete', category: 'Coordination' },
  { item: 'Interview schedule grid finalized and sent to Ana', owner: 'Adam', deadline: 'Apr 6', status: 'Complete', category: 'Coordination' },
  { item: 'Guru — 103 users confirmed', owner: 'Ana', deadline: 'Apr 6', status: 'Complete', category: 'Access' },
  { item: 'Chathura survey email — all 5 surveys sent to 57 recipients', owner: 'Chathura', deadline: 'Apr 6', status: 'Complete', category: 'Coordination' },
  { item: 'CloudTrail access escalation', owner: 'Adam → Chathura', deadline: 'Apr 6', status: 'Complete', category: 'Access' },
  { item: 'Ana + Chathura coordination update', owner: 'Adam', deadline: 'Apr 5', status: 'Complete', category: 'Coordination' },
  { item: 'All 5 surveys built in Microsoft Forms', owner: 'Adam', deadline: 'Apr 5', status: 'Complete', category: 'Coordination' },
];

const accessRows = [
  { system: 'Mad Mobile Email', status: 'Active', confirmed: 'Mar 28', notes: 'adam.lazarus@madmobile.com' },
  { system: 'Microsoft Teams', status: 'Active', confirmed: 'Mar 28', notes: 'Connected to Global Hub' },
  { system: 'Bitbucket (4 orgs)', status: 'Active', confirmed: 'Apr 1', notes: 'MadMobile, Sysco Labs, Mad Payments, Sysco Labs Conf. GitHub departing (cost).' },
  { system: 'Jira / Confluence', status: 'Active', confirmed: 'Apr 1', notes: 'API tokens working' },
  { system: 'AWS SSO (18 accounts)', status: 'Active', confirmed: 'Apr 2', notes: 'Global-Audit-RO role, CLI configured' },
  { system: 'CloudTrail', status: 'Active', confirmed: 'Apr 6', notes: 'Chathura approved LookupEvents — waiting on IT to add to role' },
  { system: 'Guru', status: 'Active', confirmed: 'Apr 6', notes: '103 users. Ana confirmed. Contract ends June, Bailey Shatney owns.' },
  { system: 'Grafana (3 instances)', status: 'Active', confirmed: 'Apr 7', notes: 'observability.madmobile.tools (CAKE), grafana.madcloud.io (Retail), grafana.madpayments.com (Payments)' },
  { system: 'Microsoft Graph API', status: 'Active', confirmed: 'Apr 7', notes: '5 read-only permissions granted. Revoke after Apr 25.' },
  { system: 'CloudWatch Alarms', status: 'Pending', confirmed: '—', notes: 'cloudwatch:DescribeAlarms not in audit role' },
];

const openItemColumns = [
  { key: 'item', label: 'Item', sortable: true, minWidth: '280px' },
  { key: 'owner', label: 'Owner', type: 'badge' as const, sortable: true },
  { key: 'deadline', label: 'Deadline', sortable: true },
  { key: 'status', label: 'Status', type: 'badge' as const, sortable: true, filterable: true, badgeMap: { Complete: 'green', Confirmed: 'green', 'In Progress': 'amber', Pending: 'muted', Blocked: 'red' } },
  { key: 'category', label: 'Category', type: 'badge' as const, sortable: true, filterable: true },
];

const accessColumns = [
  { key: 'system', label: 'System', sortable: true },
  { key: 'status', label: 'Status', type: 'badge' as const, sortable: true, badgeMap: { Active: 'green', Pending: 'amber' } },
  { key: 'confirmed', label: 'Confirmed', sortable: true },
  { key: 'notes', label: 'Notes' },
];
---

<BaseLayout title="Timeline & Status">
  <SectionHeader
    eyebrow="TIMELINE & STATUS"
    title="Engagement Timeline"
    description="Pre-work through deliverables. Every milestone has an owner, a date, and an explicit status."
  />

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Pre-Work" value="7 rounds" subtitle="V1–V7 complete" />
    <MetricCard label="Data Artifacts" value="31 charts, 17 CSVs" subtitle="94 Confluence pages extracted" />
    <MetricCard label="Access" value="9 of 10" subtitle="Only CloudWatch alarms pending" />
    <MetricCard label="Surveys" value="38 responses" subtitle="67% of 57 recipients. Closed Apr 10" />
  </dl>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Pre-Work Milestones</h2>
    <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5">
      <MilestoneStep
        date="Mar 24–28"
        title="Don briefs Chathura and Kennedy"
        detail="Coordination brief and NotebookLM materials shared with MM leadership."
        status="complete"
      />
      <MilestoneStep
        date="Mar 28–Apr 1"
        title="System access provisioned"
        detail="MM email, Teams, Bitbucket (4 orgs), Jira/Confluence, AWS SSO (18 accounts) all active."
        status="complete"
      />
      <MilestoneStep
        date="Apr 1–3"
        title="V1–V6 system reconnaissance"
        detail="Automated scans across all platforms. 29+ charts, 168-user audit, engagement minisite built."
        status="complete"
      />
      <MilestoneStep
        date="Apr 3"
        title="April 3 reorg mapped"
        detail="Siegel/Lodes exits, Chathura promoted to CDO, Kennedy narrowed. Org chart remapped. Survey 5 designed. CDO org chart received from Chathura."
        status="complete"
      />
      <MilestoneStep
        date="Apr 3–4"
        title="V7 deep collection"
        detail="25 enrichment items: epic completion (27.7%), incident timeline (50 RCAs), reviewer network (1,464 edges), pipeline reliability (60.7%), ECS health checks (90% missing)."
        status="complete"
      />
      <MilestoneStep
        date="Apr 5"
        title="Don touchbase — reorg alignment"
        detail="Reorg-specific questions: Kennedy/Winmark, Strainick appointment, board deck. V7 findings briefed. Bloom Intelligence added to scope."
        status="complete"
      />
      <MilestoneStep
        date="Apr 5 evening"
        title="Ana + Chathura coordination update sent"
        detail="Combined email with survey links, open items, 90-day plan acknowledgment. All 5 survey links, Winmark/Bloom items, vendor spend request."
        status="complete"
      />
      <MilestoneStep
        date="Apr 5 evening"
        title="90-day plan and 52-week cash flow received and analyzed"
        detail="Board-approved 90-day plan, 52-week cash flow model, revenue by product, cost reduction targets, and vendor AP data. Key finding: $278K/month committed cost cuts (AWS $50K, software $50K, headcount $178K)."
        status="complete"
      />
      <MilestoneStep
        date="Apr 6"
        title="Ana/Chathura replies processed — neo-workspace discovered"
        detail="Survey 5 confirmed. CloudTrail approved. GitHub departing. neo-workspace repo = Winmark/Neo codebase (key finding). Graph API steps sent to IT. Vendor spend partial data received."
        status="complete"
      />
      <MilestoneStep
        date="Apr 6–7"
        title="MUST interviews booked — all TBD slots filled by Chathura"
        detail="Ana booked all MUST sessions. Chathura confirmed 6 TBD interview slots (Baine, Oliver, Budd, Akula, Renard, Lee). All 27 sessions confirmed on Microsoft calendar by April 9. Wenushka Dikowita (W2) and Jeremy Diggins (W4) resolved. 38 survey responses received (67% of 57)."
        status="complete"
      />
      <MilestoneStep
        date="Apr 6–10"
        title="Don Sessions 2, 3, and pre-onsite touchbase"
        detail="Session 2: political landscape and hypotheses. Session 3: pre-onsite briefing with synthesized findings. Friday April 10 evening: final touchbase — synced on current status, aligned on Don's goals for next week."
        status="complete"
      />
      <MilestoneStep
        date="Apr 10–12"
        title="Survey close and final prep"
        detail="Surveys closed April 10 with 38 responses (67%). Don touchbase complete. Final prep Sunday evening: survey analysis, hypothesis scorecard, onsite materials, interview question review."
        status="active"
      />
      <MilestoneStep
        date="Apr 13–15"
        title="Onsite diagnostic sprint"
        detail={`Tampa HQ. ${onsiteSessionsSummary}, architecture walkthroughs, value stream mapping, real case tracing.`}
        status="upcoming"
      />
      <MilestoneStep
        date="Apr 16–25"
        title="Deliverables"
        detail="CEO operating brief, friction register, hypothesis scorecard, 30/60/90 plan, board-ready presentation, survey package."
        status="upcoming"
        last={true}
      />
    </div>
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Open Items</h2>
    <TabulatorGrid
      columns={openItemColumns}
      rows={openItems}
      searchable={true}
    />
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Access Status</h2>
    <TabulatorGrid
      columns={accessColumns}
      rows={accessRows}
    />
  </div>
</BaseLayout>
