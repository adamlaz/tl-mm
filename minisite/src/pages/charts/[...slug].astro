    { slug: 'jira_flow_distribution', title: 'Flow Distribution', domain: 'Delivery' },
    { slug: 'jira_flow_distribution_engineering', title: 'Flow Distribution (Engineering)', domain: 'Delivery' },
    { slug: 'jira_created_vs_resolved', title: 'Created vs Resolved', domain: 'Delivery' },
    { slug: 'jira_issue_distribution', title: 'Issue Distribution', domain: 'Delivery' },
    { slug: 'jira_issue_distribution_engineering', title: 'Issue Distribution (Engineering)', domain: 'Delivery' },
    { slug: 'jira_issue_distribution_overall', title: 'Issue Distribution (Overall)', domain: 'Delivery' },
    { slug: 'jira_epic_completion', title: 'Epic Completion', domain: 'Delivery' },
