  return charts.map((chart) => ({
    params: { slug: chart.slug },
    props: chart,
  }));
};

interface Props {
  slug: string;
  title: string;
  domain: string;
}

const { title, domain, slug } = Astro.props;
const chartPath = resolve('../analysis/charts', `${slug}.json`);
const hasData = existsSync(chartPath);
const chartData = hasData ? readFileSync(chartPath, 'utf-8') : '';
---

<BaseLayout title={`${title} — ${domain}`}>
  <div class="mb-4">
    <div class="flex items-center gap-2 text-xs text-[var(--text-muted)] mb-2">
      <a href="/charts" class="hover:text-[var(--accent)] transition-colors">Charts</a>
      <span>/</span>
      <span>{domain}</span>
      <span>/</span>
      <span class="text-[var(--text-secondary)]">{title}</span>
    </div>
    <h1 class="text-lg font-bold text-[var(--text)]">{title}</h1>
  </div>

  {hasData ? (
    <div class="rounded-xl border border-[var(--border)] overflow-hidden h-[calc(100vh-220px)]" data-echarts>
      <script type="application/json" set:html={chartData} />
    </div>
  ) : (
    <div class="rounded-xl border border-[var(--border)] overflow-hidden h-[calc(100vh-220px)] flex items-center justify-center bg-[var(--surface-alt)]">
      <p class="text-sm text-[var(--text-muted)]">Chart data not generated yet</p>
    </div>
  )}
</BaseLayout>
