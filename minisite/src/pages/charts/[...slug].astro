    { slug: 'commit_calendar', title: 'Commit Calendar', domain: 'Engineering' },
    { slug: 'build_duration_range', title: 'Build Duration Bands', domain: 'Engineering' },
    { slug: 'jira_org_overview', title: 'Org Overview', domain: 'Delivery' },
    { slug: 'jira_velocity_trend', title: 'Velocity Trend', domain: 'Delivery' },
