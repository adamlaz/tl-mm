---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { readdirSync } from 'node:fs';
import { resolve } from 'node:path';

function slugToTitle(slug: string): string {
  return slug
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase())
    .replace(/\bAws\b/g, 'AWS')
    .replace(/\bBb\b/g, 'BB')
    .replace(/\bPr\b/g, 'PR')
    .replace(/\bDora\b/g, 'DORA')
    .replace(/\bKpi\b/g, 'KPI')
    .replace(/\bRca\b/g, 'RCA')
    .replace(/\bEcs\b/g, 'ECS')
    .replace(/\bEks\b/g, 'EKS')
    .replace(/\bRds\b/g, 'RDS')
    .replace(/\bM365\b/g, 'M365')
    .replace(/\bSl\b/g, 'SL')
    .replace(/\bCi\b/g, 'CI')
    .replace(/\bCd\b/g, 'CD');
}

function guessDomain(slug: string): string {
  if (slug.startsWith('aws_')) return 'Infrastructure';
  if (slug.startsWith('bitbucket_') || slug.startsWith('bb_') || slug.startsWith('review_') || slug.startsWith('commit_') || slug.startsWith('build_') || slug.startsWith('pr_') || slug.startsWith('repo_') || slug.startsWith('workspace_') || slug.startsWith('pipeline_') || slug.startsWith('dora_')) return 'Engineering';
  if (slug.startsWith('jira_') || slug.startsWith('sprint_') || slug.startsWith('kpi_')) return 'Delivery';
  if (slug.startsWith('confluence_')) return 'Documentation';
  if (slug.startsWith('meeting_') || slug.startsWith('org_') || slug.startsWith('people_') || slug.startsWith('team_') || slug.startsWith('key_person') || slug.startsWith('activity_') || slug.startsWith('communication_') || slug.startsWith('geography_') || slug.startsWith('centrality_') || slug.startsWith('network_') || slug.startsWith('bridge_') || slug.startsWith('unified_') || slug.startsWith('divergence_') || slug.startsWith('relevance_') || slug.startsWith('m365_')) return 'People';
  if (slug.startsWith('revenue_') || slug.startsWith('cash_flow') || slug.startsWith('vendor_') || slug.startsWith('risk_') || slug.startsWith('cost_') || slug.startsWith('retail_')) return 'Financial';
  if (slug.startsWith('hypothesis_') || slug.startsWith('reorg_') || slug.startsWith('engagement_') || slug.startsWith('methodology_')) return 'Engagement';
  if (slug.startsWith('user_') || slug.startsWith('bus_') || slug.startsWith('deploy_') || slug.startsWith('identity_')) return 'Cross-System';
  return 'Other';
}

const domainOrder = ['Infrastructure', 'Engineering', 'Delivery', 'Documentation', 'Financial', 'People', 'Cross-System', 'Engagement', 'Other'];

const chartsDir = resolve('../analysis/charts');
const files = readdirSync(chartsDir).filter(
  (f) => f.endsWith('.json') && !f.startsWith('_')
);

const allCharts = files.map((f) => {
  const slug = f.replace('.json', '');
  return { slug, title: slugToTitle(slug), domain: guessDomain(slug) };
});

const grouped = new Map<string, typeof allCharts>();
for (const chart of allCharts) {
  const list = grouped.get(chart.domain) ?? [];
  list.push(chart);
  grouped.set(chart.domain, list);
}

const chartGroups = domainOrder
  .filter((d) => grouped.has(d))
  .map((d) => ({ domain: d, charts: grouped.get(d)!.sort((a, b) => a.title.localeCompare(b.title)) }));

const totalCharts = allCharts.length;
---

<BaseLayout title="Charts">
  <SectionHeader
    eyebrow="CHART GALLERY"
    title="Chart Gallery"
    description={`${totalCharts} interactive visualizations generated from infrastructure, engineering, delivery, financial, people, and documentation data. Each chart is explorable -- scroll to zoom, drag to pan, and click the fullscreen button for a full-viewport view.`}
  />

  <div class="space-y-8">
    {chartGroups.map(({ domain, charts }) => (
      <div>
        <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">
          {domain} <span class="text-[var(--text-muted)] font-mono">({charts.length})</span>
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {charts.map(({ slug, title }) => (
            <a
              href={`/charts/${slug}`}
              class="group bg-[var(--surface)] rounded-xl border border-[var(--border)] px-4 py-3 hover:border-[var(--accent)] hover:shadow-sm transition-all flex items-center gap-3"
            >
              <svg
                class="w-5 h-5 text-[var(--text-muted)] group-hover:text-[var(--accent)] transition-colors flex-shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 20V10M18 20V4M6 20v-4" />
              </svg>
              <span class="text-sm font-medium text-[var(--text-secondary)] group-hover:text-[var(--accent)] transition-colors">
                {title}
              </span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
