---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MetricCard from '../components/MetricCard.astro';

const phases = [
  { phase: 'Pre-Work', timeline: 'Now → Apr 11', status: 'Complete', detail: 'System scanning, automated surveys, and 7 rounds of AI-driven reconnaissance (V1–V7) across Jira, Bitbucket, Confluence, AWS, and HR data — before the first interview.' },
  { phase: 'Onsite', timeline: 'Apr 13–15', status: 'Upcoming', detail: '3-day sprint in Tampa: 18–21 structured interviews, architecture walkthroughs, value stream mapping, and decision-rights tracing with data-backed questions.' },
  { phase: 'Deliverables', timeline: 'Apr 16–25', status: 'Pending', detail: 'CEO operating brief, friction register, hypothesis scorecard, and 30/60/90 execution plan — evidence-based, actionable, no filler.' },
];

const explore = [
  { href: '/engagement/timeline', title: 'Timeline & Status', desc: 'Pre-work milestones, upcoming dates, open items, and data gaps.', metric: '12', metricLabel: 'milestones' },
  { href: '/engagement/hypotheses', title: 'Hypotheses', desc: 'Nine execution-failure patterns with quantitative pre-evidence from 7 rounds of system scans.', metric: '9', metricLabel: 'patterns' },
  { href: '/engagement/leadership', title: 'Leadership', desc: 'Post-reorg org structure: two C-suite exits, CDO promotion, and ~100-person org consolidation.', metric: '8', metricLabel: 'executives' },
  { href: '/engagement/interviews', title: 'Interviews', desc: 'Three-day onsite schedule with data-driven questions for every session.', metric: '18–21', metricLabel: 'sessions' },
  { href: '/engagement/deliverables', title: 'Deliverables', desc: 'CEO operating brief, friction register, 30/60/90 plan, and the diagnostic framework.', metric: '5+', metricLabel: 'core outputs' },
];
---

<BaseLayout title="Engagement">
  <SectionHeader
    eyebrow="ENGAGEMENT OVERVIEW"
    title="CEO Ramp Accelerator"
    description="A ~60-hour compressed technology and operations diagnostic for Mad Mobile, Inc. — automated system reconnaissance, 18–21 onsite interviews, and an evidence-based operating brief."
  />

  <div class="bg-[var(--surface)] border border-[var(--border)] rounded-xl p-5 mb-8">
    <div class="grid sm:grid-cols-2 gap-6">
      <div>
        <h3 class="text-[10px] font-medium uppercase tracking-[0.08em] text-[var(--text-muted)] mb-2">What this is</h3>
        <ul class="space-y-1.5 text-xs text-[var(--text-secondary)] leading-relaxed">
          <li class="flex gap-2"><span class="text-[var(--status-green)] shrink-0">●</span>~60-hour compressed diagnostic across 3 weeks</li>
          <li class="flex gap-2"><span class="text-[var(--status-green)] shrink-0">●</span>AI-driven system reconnaissance before the first interview</li>
          <li class="flex gap-2"><span class="text-[var(--status-green)] shrink-0">●</span>18–21 structured interviews with data-backed questions</li>
          <li class="flex gap-2"><span class="text-[var(--status-green)] shrink-0">●</span>Evidence-based operating brief Don can act on immediately</li>
        </ul>
      </div>
      <div>
        <h3 class="text-[10px] font-medium uppercase tracking-[0.08em] text-[var(--text-muted)] mb-2">What it isn't</h3>
        <ul class="space-y-1.5 text-xs text-[var(--text-secondary)] leading-relaxed">
          <li class="flex gap-2"><span class="text-[var(--text-muted)] shrink-0">○</span>A personnel review or performance evaluation</li>
          <li class="flex gap-2"><span class="text-[var(--text-muted)] shrink-0">○</span>An exhaustive code audit</li>
          <li class="flex gap-2"><span class="text-[var(--text-muted)] shrink-0">○</span>A six-month consulting program</li>
          <li class="flex gap-2"><span class="text-[var(--text-muted)] shrink-0">○</span>Blame-focused — systems-focused, anonymous interviews, only patterns reported</li>
        </ul>
      </div>
    </div>
  </div>

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Duration" value="3 wks" subtitle="~60 hours total" />
    <MetricCard label="Interviews" value="18–21" subtitle="Onsite Apr 13–15" />
    <MetricCard label="Hypotheses" value="9" subtitle="1 confirmed pre-onsite" />
    <MetricCard label="Pre-Work" value="7 rounds" subtitle="V1–V7 automated scans" />
  </dl>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">Phase Timeline</h2>
    <div class="grid gap-4 sm:grid-cols-3">
      {phases.map((p) => (
        <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-[var(--text)]">
              {p.phase}
            </span>
            <span
              class:list={[
                'text-[10px] font-medium uppercase tracking-wider px-2 py-0.5 rounded-full',
                p.status === 'Complete'
                  ? 'text-[var(--status-green)] bg-[var(--status-green-bg)]'
                  : p.status === 'Upcoming'
                    ? 'text-[var(--status-amber)] bg-[var(--status-amber-bg)]'
                    : 'bg-[var(--surface-alt)] text-[var(--text-muted)]',
              ]}
            >
              {p.status}
            </span>
          </div>
          <p class="text-xs font-mono text-[var(--accent)] mb-2">{p.timeline}</p>
          <p class="text-xs text-[var(--text-secondary)] leading-relaxed">{p.detail}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">Company Snapshot</h2>
    <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5">
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
        <div>
          <dt class="text-[var(--text-muted)] text-xs uppercase tracking-wider">Revenue</dt>
          <dd class="font-mono font-semibold text-[var(--text)]">~$75M</dd>
        </div>
        <div>
          <dt class="text-[var(--text-muted)] text-xs uppercase tracking-wider">Headcount</dt>
          <dd class="font-mono font-semibold text-[var(--text)]">~370</dd>
        </div>
        <div>
          <dt class="text-[var(--text-muted)] text-xs uppercase tracking-wider">Funding</dt>
          <dd class="font-mono font-semibold text-[var(--text)]">$70M</dd>
        </div>
        <div>
          <dt class="text-[var(--text-muted)] text-xs uppercase tracking-wider">Locations</dt>
          <dd class="font-mono font-semibold text-[var(--text)]">21K+</dd>
        </div>
      </dl>
      <p class="text-xs text-[var(--text-secondary)] mt-4 leading-relaxed">
        Tampa HQ + Sri Lanka engineering. Key partnerships: Sysco, Visa, Best Buy, Apple. Products: CAKE POS
        (restaurant), Concierge (retail), Neo (AI platform). CAKE acquired from Sysco in 2020.
      </p>
    </div>
  </div>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Explore</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {explore.map(({ href, title, desc, metric, metricLabel }) => (
      <a
        href={href}
        class="group bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5 hover:border-[var(--accent)] hover:shadow-sm transition-all"
      >
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-base font-semibold text-[var(--text)] group-hover:text-[var(--accent)] transition-colors">
            {title}
          </h3>
          <span class="text-lg font-mono font-semibold text-[var(--accent)] tabular-nums">{metric}</span>
        </div>
        <p class="text-xs text-[var(--text-secondary)]">{desc}</p>
        <p class="text-[10px] text-[var(--text-muted)] mt-1 uppercase tracking-wider">{metricLabel}</p>
      </a>
    ))}
  </div>
</BaseLayout>
