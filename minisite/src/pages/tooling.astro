---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MetricCard from '../components/MetricCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import TabulatorGrid from '../components/TabulatorGrid.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'node:fs';

const tools = await getCollection('toolingCatalog');

const byCategory = new Map<string, typeof tools>();
for (const t of tools) {
  const cat = t.data.category;
  const list = byCategory.get(cat) ?? [];
  list.push(t);
  byCategory.set(cat, list);
}

const categories = [...byCategory.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const activeCount = tools.filter((t) => t.data.status === 'confirmed_active').length;
const inferredCount = tools.filter((t) => t.data.status === 'inferred').length;
const categoryCount = byCategory.size;

let aiToolingDocs: Record<string, any[]> | null = null;
try {
  aiToolingDocs = JSON.parse(readFileSync('../inventory/confluence/ai_tooling_docs.json', 'utf-8'));
} catch {}

let toolingExpenseDocs: Record<string, any[]> | null = null;
try {
  toolingExpenseDocs = JSON.parse(readFileSync('../inventory/confluence/tooling_expense_docs.json', 'utf-8'));
} catch {}

function formatDate(iso: string): string {
  if (!iso) return '';
  return iso.slice(0, 10);
}

const aiRows: Record<string, string>[] = [];
if (aiToolingDocs) {
  const sections: [string, string][] = [
    ['cursor_title', 'Cursor IDE'],
    ['ai_tooling', 'AI Workflows'],
    ['ai_strategy', 'AI Strategy'],
    ['lovable', 'Lovable / Low-Code'],
  ];
  for (const [key, label] of sections) {
    const items = aiToolingDocs[key];
    if (Array.isArray(items)) {
      for (const item of items) {
        if (item.title && !item.title.endsWith('.csv') && !item.title.endsWith('.pdf') && !item.title.endsWith('.png') && !item.title.endsWith('.json')) {
          aiRows.push({ category: label, title: item.title, space: item.space ?? '', modified: formatDate(item.last_modified) });
        }
      }
    }
  }
}

const expenseRows: Record<string, string>[] = [];
if (toolingExpenseDocs) {
  const sections: [string, string][] = [
    ['tool_inventory', 'Tool Inventories'],
    ['budget_cost', 'Cost Analysis'],
    ['vendors', 'Vendor Contracts'],
  ];
  for (const [key, label] of sections) {
    const items = toolingExpenseDocs[key];
    if (Array.isArray(items)) {
      for (const item of items) {
        if (item.title && !item.title.endsWith('.csv') && !item.title.endsWith('.pdf') && !item.title.endsWith('.png') && !item.title.endsWith('.json') && !item.title.endsWith('.docx') && !item.title.endsWith('.xlsx') && !item.title.endsWith('.xls')) {
          expenseRows.push({ category: label, title: item.title, space: item.space ?? '', modified: formatDate(item.last_modified) });
        }
      }
    }
  }
}
---

<BaseLayout title="Tooling">
  <SectionHeader
    title="Vendor & Tool Catalog"
    description="All identified tools and vendors in the Mad Mobile technology stack."
  />

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Total Tools" value={tools.length.toString()} />
    <MetricCard label="Confirmed Active" value={activeCount.toString()} />
    <MetricCard label="Inferred" value={inferredCount.toString()} />
    <MetricCard label="Categories" value={categoryCount.toString()} />
  </dl>

  <div class="space-y-8">
    {categories.map(([category, categoryTools]) => (
      <div>
        <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">{category}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {categoryTools.map((t) => (
            <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-4">
              <div class="flex items-start justify-between mb-2">
                <div>
                  <h3 class="text-sm font-semibold text-[var(--text)]">{t.data.name}</h3>
                  <p class="text-xs text-[var(--text-secondary)]">{t.data.vendor}</p>
                </div>
                <StatusBadge status={t.data.status} />
              </div>
              {t.data.notes && <p class="text-xs text-[var(--text-secondary)] mt-2 leading-relaxed">{t.data.notes}</p>}
              <div class="flex items-center gap-3 mt-3 pt-2 border-t border-[var(--border-subtle)]">
                <span class="text-[10px] uppercase tracking-wider text-[var(--text-muted)]">Cost</span>
                <span class="text-xs text-[var(--text-secondary)]">{t.data.cost_detail ?? t.data.cost_status}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  {aiRows.length > 0 && (
    <div class="mt-12">
      <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">AI Tooling References</h2>
      <p class="text-xs text-[var(--text-secondary)] mb-4">Confluence pages referencing AI tools, coding assistants, and automation frameworks used at Mad Mobile.</p>
      <TabulatorGrid
        columns={[
          { key: 'category', label: 'Category', sortable: true, filterable: true, type: 'badge' },
          { key: 'title', label: 'Page Title', sortable: true },
          { key: 'space', label: 'Space', sortable: true, filterable: true, type: 'badge' },
          { key: 'modified', label: 'Last Modified', sortable: true, type: 'date' },
        ]}
        rows={aiRows}
        searchable
        pageSize={15}
        exportable
      />
    </div>
  )}

  {expenseRows.length > 0 && (
    <div class="mt-12">
      <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">Tooling Expense Documentation</h2>
      <p class="text-xs text-[var(--text-secondary)] mb-4">Confluence pages related to tool inventories, vendor contracts, licensing, and cost analysis.</p>
      <TabulatorGrid
        columns={[
          { key: 'category', label: 'Category', sortable: true, filterable: true, type: 'badge' },
          { key: 'title', label: 'Page Title', sortable: true },
          { key: 'space', label: 'Space', sortable: true, filterable: true, type: 'badge' },
          { key: 'modified', label: 'Last Modified', sortable: true, type: 'date' },
        ]}
        rows={expenseRows}
        searchable
        pageSize={15}
        exportable
      />
    </div>
  )}
</BaseLayout>
