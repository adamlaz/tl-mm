---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MetricCard from '../components/MetricCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import TabulatorGrid from '../components/TabulatorGrid.astro';
import ChartEmbed from '../components/ChartEmbed.astro';
import FindingCard from '../components/FindingCard.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'node:fs';

const tools = await getCollection('toolingCatalog');

const byCategory = new Map<string, typeof tools>();
for (const t of tools) {
  const cat = t.data.category;
  const list = byCategory.get(cat) ?? [];
  list.push(t);
  byCategory.set(cat, list);
}

const categories = [...byCategory.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const validTools = tools.filter((t) => t.data.notes !== 'Duplicate entry removed — see Grafana above.');
const activeCount = validTools.filter((t) => t.data.status === 'confirmed_active').length;
const suspectedCount = validTools.filter((t) => t.data.status === 'suspected').length;
const categoryCount = byCategory.size;

const withOverlap = validTools.filter((t) => t.data.overlap_with && t.data.overlap_with.length > 0);
const withCost = validTools.filter((t) => t.data.estimated_annual_cost);

const byVendor = new Map<string, typeof validTools>();
for (const t of validTools) {
  const v = t.data.vendor;
  const list = byVendor.get(v) ?? [];
  list.push(t);
  byVendor.set(v, list);
}
const vendorGroups = [...byVendor.entries()].sort((a, b) => b[1].length - a[1].length);

const overlapGroups = [
  { area: 'Observability', tools: ['Grafana (self-hosted)', 'Datadog', 'Nagios', 'Munin', 'Graylog', 'DB Cacti'], severity: 'red' as const, detail: '6 monitoring/observability tools running in parallel. Grafana stack (Mimir/Loki/Tempo) in Shared Services, Datadog for Concierge/MenuPad, plus 4 legacy tools. Consolidation could save $50K–$200K/year (Datadog) and significant operational overhead.' },
  { area: 'Source Control', tools: ['Bitbucket Cloud', 'GitHub'], severity: 'amber' as const, detail: 'Dual source control. Internal Confluence page already asks "Can we get rid of this?" about GitHub. If still paying, immediate savings opportunity.' },
  { area: 'CI/CD', tools: ['Jenkins', 'Bitbucket Pipelines'], severity: 'amber' as const, detail: '9 Jenkins instances in CAKE Dev (~$18–30K/year hosting) alongside Bitbucket Pipelines. Internal tooling evaluation scored Jenkins lowest. 0 of top-80 recent repos use Jenkins.' },
  { area: 'Package Registry', tools: ['AWS CodeArtifact', 'NpmJS', 'Archiva', 'DockerHub', 'Amazon ECR'], severity: 'amber' as const, detail: '5 artifact/registry services. CodeArtifact costs $13/month — consolidating to it from NpmJS and Archiva would simplify operations.' },
  { area: 'Communication', tools: ['Microsoft Teams', 'Slack'], severity: 'amber' as const, detail: 'Both listed on engineering laptop setup. If both are paid, one should be primary.' },
  { area: 'BI / Analytics', tools: ['Domo', 'AWS QuickSight'], severity: 'amber' as const, detail: 'Two BI platforms. QuickSight used for FinOps dashboards, Domo for product analytics.' },
  { area: 'Cloud Security', tools: ['Wiz.io', 'Trend Micro Cloud One'], severity: 'amber' as const, detail: 'Wiz across all 18 accounts + Trend Micro at $1,438/mo in CAKE Dev. Potentially redundant CSPM/CWPP.' },
];

let aiToolingDocs: Record<string, any[]> | null = null;
try {
  aiToolingDocs = JSON.parse(readFileSync('../inventory/confluence/ai_tooling_docs.json', 'utf-8'));
} catch {}

let toolingExpenseDocs: Record<string, any[]> | null = null;
try {
  toolingExpenseDocs = JSON.parse(readFileSync('../inventory/confluence/tooling_expense_docs.json', 'utf-8'));
} catch {}

function formatDate(iso: string): string {
  if (!iso) return '';
  return iso.slice(0, 10);
}

const aiRows: Record<string, string>[] = [];
if (aiToolingDocs) {
  const sections: [string, string][] = [
    ['cursor_title', 'Cursor IDE'],
    ['ai_tooling', 'AI Workflows'],
    ['ai_strategy', 'AI Strategy'],
    ['lovable', 'Lovable / Low-Code'],
  ];
  for (const [key, label] of sections) {
    const items = aiToolingDocs[key];
    if (Array.isArray(items)) {
      for (const item of items) {
        if (item.title && !item.title.endsWith('.csv') && !item.title.endsWith('.pdf') && !item.title.endsWith('.png') && !item.title.endsWith('.json')) {
          aiRows.push({ category: label, title: item.title, space: item.space ?? '', modified: formatDate(item.last_modified) });
        }
      }
    }
  }
}

const expenseRows: Record<string, string>[] = [];
if (toolingExpenseDocs) {
  const sections: [string, string][] = [
    ['tool_inventory', 'Tool Inventories'],
    ['budget_cost', 'Cost Analysis'],
    ['vendors', 'Vendor Contracts'],
  ];
  for (const [key, label] of sections) {
    const items = toolingExpenseDocs[key];
    if (Array.isArray(items)) {
      for (const item of items) {
        if (item.title && !item.title.endsWith('.csv') && !item.title.endsWith('.pdf') && !item.title.endsWith('.png') && !item.title.endsWith('.json') && !item.title.endsWith('.docx') && !item.title.endsWith('.xlsx') && !item.title.endsWith('.xls')) {
          expenseRows.push({ category: label, title: item.title, space: item.space ?? '', modified: formatDate(item.last_modified) });
        }
      }
    }
  }
}
---

<BaseLayout title="Tooling">
  <SectionHeader
    eyebrow="TOOLING"
    title="Vendor & Tool Catalog"
    description="48 tools identified across Mad Mobile's technology stack. Enriched with Confluence page extraction, AWS cost attribution, Bitbucket dependency scanning, and public pricing estimates. Updated April 5, 2026 (V8)."
  />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <FindingCard severity="red" title="6 Observability Tools" detail="Grafana/Mimir/Loki/Tempo, Datadog, Nagios, Munin, Graylog, DB Cacti — running in parallel. Consolidation is the single biggest tooling savings opportunity." evidence="6 tools across Confluence and AWS inventory" />
    <FindingCard severity="amber" title="75% of Tool Costs Unknown" detail="Only AWS ($3.8M/year) and a few line items have real cost data. Estimated non-AWS SaaS spend: $350K–$800K/year. Finance data needed." evidence="48 tools, 36 with unknown costs" />
    <FindingCard severity="amber" title="7 Overlap Areas Identified" detail="Dual CI/CD, dual source control, dual communication, dual BI, dual cloud security, 5 package registries, and 6 observability tools." evidence="System scan + Confluence extraction" />
  </div>

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Total Tools" value={validTools.length.toString()} />
    <MetricCard label="Confirmed Active" value={activeCount.toString()} />
    <MetricCard label="Suspected" value={suspectedCount.toString()} />
    <MetricCard label="Overlap Areas" value="7" />
  </dl>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">TOOL OVERLAP & REDUNDANCY</h2>
    <p class="text-xs text-[var(--text-secondary)] mb-4">Areas where multiple tools serve the same function. Each represents a consolidation opportunity — both cost savings and operational simplification.</p>
    <div class="grid sm:grid-cols-2 gap-4">
      {overlapGroups.map((g) => (
        <FindingCard severity={g.severity} title={`${g.area}: ${g.tools.length} tools`} detail={g.detail} evidence={g.tools.join(', ')} />
      ))}
    </div>
  </div>

  <div class="mb-10">
    <ChartEmbed slug="workspace_health_radar" title="Workspace Engineering Health" description="Normalized 0–100 scores across 4 Bitbucket workspaces. Quality variance is a tooling and process story." interactive />
  </div>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">DORA Cross-Reference: Self-Report vs System Data</h2>
    <TabulatorGrid
      columns={[
        { key: 'metric', label: 'DORA Metric', sortable: false },
        { key: 'source', label: 'System Data Source', sortable: false },
        { key: 'actual', label: 'Pre-Work Finding', sortable: false },
      ]}
      rows={[
        { metric: 'Deploy Frequency', source: 'Bitbucket deploy tags, release branches', actual: 'Varies by workspace — madpayments highest cadence' },
        { metric: 'Lead Time', source: 'PR cycle time', actual: '0.6h (cloud-shared-dev) to 235h (concierge-associate)' },
        { metric: 'Change Failure Rate', source: 'Jira bug creation rate', actual: '11,985 total bugs, ~916 issues created/month' },
        { metric: 'Recovery Time', source: 'Grafana MTTR dashboards', actual: 'Pending — Grafana access confirmed Apr 6' },
        { metric: 'Reliability', source: 'CloudWatch alarms', actual: 'Pending — cloudwatch:DescribeAlarms not in audit role' },
      ]}
    />
  </div>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">TOP VENDORS BY TOOL COUNT</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {vendorGroups.slice(0, 8).map(([vendor, vTools]) => (
        <div class="bg-[var(--surface)] rounded-lg border border-[var(--border)] p-3">
          <p class="text-xs font-semibold text-[var(--text)]">{vendor}</p>
          <p class="text-2xl font-bold text-[var(--text)] mt-1">{vTools.length}</p>
          <p class="text-[10px] text-[var(--text-muted)] mt-1">{vTools.map(t => t.data.name).join(', ')}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="space-y-8">
    {categories.map(([category, categoryTools]) => (
      <div>
        <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">{category}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {categoryTools.filter(t => t.data.notes !== 'Duplicate entry removed — see Grafana above.').map((t) => (
            <div class={`bg-[var(--surface)] rounded-xl border p-4 ${t.data.overlap_with && t.data.overlap_with.length > 0 ? 'border-amber-500/40' : 'border-[var(--border)]'}`}>
              <div class="flex items-start justify-between mb-2">
                <div>
                  <h3 class="text-sm font-semibold text-[var(--text)]">{t.data.name}</h3>
                  <p class="text-xs text-[var(--text-secondary)]">{t.data.vendor}</p>
                </div>
                <StatusBadge status={t.data.status} />
              </div>
              {t.data.notes && <p class="text-xs text-[var(--text-secondary)] mt-2 leading-relaxed">{t.data.notes}</p>}
              <div class="mt-3 pt-2 border-t border-[var(--border-subtle)] space-y-1">
                {t.data.estimated_annual_cost && (
                  <div class="flex items-center gap-2">
                    <span class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] w-16">Est. Cost</span>
                    <span class="text-xs font-medium text-[var(--text)]">{t.data.estimated_annual_cost}</span>
                  </div>
                )}
                {t.data.pricing_model && (
                  <div class="flex items-center gap-2">
                    <span class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] w-16">Model</span>
                    <span class="text-xs text-[var(--text-secondary)]">{t.data.pricing_model.replace(/_/g, ' ')}</span>
                  </div>
                )}
                {t.data.teams_using && t.data.teams_using.length > 0 && (
                  <div class="flex items-start gap-2">
                    <span class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] w-16 pt-0.5">Teams</span>
                    <span class="text-xs text-[var(--text-secondary)]">{t.data.teams_using.join(', ')}</span>
                  </div>
                )}
                {t.data.overlap_with && t.data.overlap_with.length > 0 && (
                  <div class="flex items-start gap-2">
                    <span class="text-[10px] uppercase tracking-wider text-amber-500 w-16 pt-0.5">Overlap</span>
                    <span class="text-xs text-amber-400">{t.data.overlap_with.join(', ')}</span>
                  </div>
                )}
                {!t.data.estimated_annual_cost && (
                  <div class="flex items-center gap-2">
                    <span class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] w-16">Cost</span>
                    <span class="text-xs text-[var(--text-secondary)]">{t.data.cost_detail ?? t.data.cost_status}</span>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  {aiRows.length > 0 && (
    <div class="mt-12">
      <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">AI Tooling References</h2>
      <p class="text-xs text-[var(--text-secondary)] mb-4">Confluence pages referencing AI tools, coding assistants, and automation frameworks used at Mad Mobile.</p>
      <TabulatorGrid
        columns={[
          { key: 'category', label: 'Category', sortable: true, filterable: true, type: 'badge' },
          { key: 'title', label: 'Page Title', sortable: true },
          { key: 'space', label: 'Space', sortable: true, filterable: true, type: 'badge' },
          { key: 'modified', label: 'Last Modified', sortable: true, type: 'date' },
        ]}
        rows={aiRows}
        searchable
        pageSize={15}
        exportable
      />
    </div>
  )}

  {expenseRows.length > 0 && (
    <div class="mt-12">
      <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">Tooling Expense Documentation</h2>
      <p class="text-xs text-[var(--text-secondary)] mb-4">Confluence pages related to tool inventories, vendor contracts, licensing, and cost analysis.</p>
      <TabulatorGrid
        columns={[
          { key: 'category', label: 'Category', sortable: true, filterable: true, type: 'badge' },
          { key: 'title', label: 'Page Title', sortable: true },
          { key: 'space', label: 'Space', sortable: true, filterable: true, type: 'badge' },
          { key: 'modified', label: 'Last Modified', sortable: true, type: 'date' },
        ]}
        rows={expenseRows}
        searchable
        pageSize={15}
        exportable
      />
    </div>
  )}

  <div class="mt-10 pt-6 border-t border-[var(--border-subtle)]">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">Related</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <FindingCard severity="red" title="60.7% Pipeline Success Rate" detail="Tooling fragmentation is a root cause — dual CI/CD contributes to build reliability issues." href="/engineering" hrefLabel="Engineering" />
      <FindingCard severity="amber" title="Survey 5: AI Adoption & Tooling" detail="Survey results will map actual tool usage vs what's paid for. Feeds vendor rationalization." href="/surveys/ai-tooling" hrefLabel="AI & Tooling Survey" />
    </div>
  </div>
</BaseLayout>
