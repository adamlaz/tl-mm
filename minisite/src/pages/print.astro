  <title>Onsite Summary | Mad Mobile Engagement</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&family=Noto+Sans+Display:wght@600;700&family=Noto+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Noto Sans', sans-serif; color: #2E2820; font-size: 11px; line-height: 1.5; padding: 24px; }
    h1 { font-family: 'Noto Sans Display', sans-serif; font-size: 20px; font-weight: 700; margin-bottom: 4px; }
    h2 { font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: #8A8070; margin-top: 20px; margin-bottom: 8px; border-bottom: 1px solid #E8E4DE; padding-bottom: 4px; }
    h3 { font-size: 12px; font-weight: 600; margin-bottom: 2px; }
    .subtitle { color: #8A8070; font-size: 11px; margin-bottom: 16px; }
    .footer { color: #8A8070; font-size: 9px; margin-top: 20px; border-top: 1px solid #E8E4DE; padding-top: 8px; display: flex; justify-content: space-between; }
    .finding { border-left: 3px solid; padding: 6px 10px; margin-bottom: 6px; background: #FAFAF8; }
    .finding-red { border-color: #CC4A3A; }
    .finding-amber { border-color: #C4973A; }
    .finding-green { border-color: #3AAA5C; }
    .finding h3 { font-size: 11px; }
    .finding p { font-size: 10px; color: #5A5048; }
    .metrics { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-bottom: 16px; }
    .metric { border: 1px solid #E8E4DE; padding: 6px 8px; border-radius: 6px; }
    .metric .value { font-family: 'Noto Sans Mono', monospace; font-size: 14px; font-weight: 600; }
    .metric .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.06em; color: #8A8070; }
    .schedule { width: 100%; border-collapse: collapse; font-size: 10px; margin-bottom: 12px; }
    .schedule th { text-align: left; font-size: 9px; text-transform: uppercase; letter-spacing: 0.06em; color: #8A8070; border-bottom: 1px solid #E8E4DE; padding: 3px 6px; }
    .schedule td { padding: 3px 6px; border-bottom: 1px solid #F0EDE8; }
    .hypothesis-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
    .hypothesis { border: 1px solid #E8E4DE; padding: 4px 8px; border-radius: 4px; font-size: 10px; }
    .hypothesis .id { font-family: 'Noto Sans Mono', monospace; font-weight: 700; font-size: 10px; }
    .questions { margin-bottom: 12px; }
    .questions li { margin-bottom: 4px; padding-left: 8px; font-size: 10px; }
    @media print {
      body { padding: 0; }
      @page { margin: 0.5in; size: letter; }
    }
  </style>
</head>
