---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const mmdPath = resolve('../inventory/mad-mobile-org-chart.mmd');
const mmdContent = readFileSync(mmdPath, 'utf-8');
---

<BaseLayout title="Org Chart">
  <SectionHeader
    title="Org Chart"
    description="Updated organization structure — April 2026. Don Salama (Co-CEO) with 7 direct reports."
  />

  <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-6 overflow-x-auto">
    <div id="org-chart" class="mermaid">
      {mmdContent}
    </div>
  </div>

  <div class="mt-6 grid sm:grid-cols-3 gap-4">
    <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-4">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-2">Digital / Engineering</h3>
      <p class="text-sm text-[var(--text-secondary)]">
        Chathura Ratnayake (CDO) — largest org. PMO, Payments (18), Enterprise Solutions (58), CAKE Tech (8), Product &
        Design (6), Customer Support.
      </p>
    </div>
    <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-4">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-2">Technology / AI</h3>
      <p class="text-sm text-[var(--text-secondary)]">
        Jack Kennedy (CTO) — narrowed to AI and innovation post-reorg. Two direct reports: Diggins and Bobal.
      </p>
    </div>
    <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-4">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-2">Key Change</h3>
      <p class="text-sm text-[var(--text-secondary)]">
        April 3 reorg: Siegel (COO) and Lodes (CRO) departed. Chathura promoted from VP Eng to CDO with authority over
        all engineering. Kennedy narrowed to AI only.
      </p>
    </div>
  </div>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script is:inline>
  document.addEventListener('astro:page-load', function () {
    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'default',
      flowchart: { htmlLabels: true, curve: 'basis' },
    });
    mermaid.run({ nodes: document.querySelectorAll('.mermaid') });
  });
</script>
