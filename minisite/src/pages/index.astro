---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import MetricCard from '../components/MetricCard.astro';
import ChartEmbed from '../components/ChartEmbed.astro';
import { getCollection } from 'astro:content';
import FindingCard from '../components/FindingCard.astro';
import { num, fmt } from '../lib/parse';
import { readFileSync, readdirSync } from 'node:fs';

const awsCosts = await getCollection('awsCosts');
const repos = await getCollection('bitbucketRepos');
const projects = await getCollection('jiraProjects');
const pages = await getCollection('confluencePages');
const tools = await getCollection('toolingCatalog');
let users: any[] = [];
try { users = await getCollection('peopleDirectory') as any; } catch {}
if (!users.length) { try { users = await getCollection('userAudit') as any; } catch {} }

const epicData = JSON.parse(readFileSync('../inventory/jira/epic_completion.json', 'utf-8'));
const rcaData = JSON.parse(readFileSync('../inventory/confluence/rca_timeline.json', 'utf-8'));
let reviewData = {};
try { reviewData = JSON.parse(readFileSync('../inventory/bitbucket/review_network_summary.json', 'utf-8')); } catch {}
const ecsData = JSON.parse(readFileSync('../inventory/aws/ecs_task_definitions.json', 'utf-8'));
const customFields = JSON.parse(readFileSync('../inventory/jira/custom_fields.json', 'utf-8'));

const totalAwsCost = awsCosts
  .filter((e) => e.data.month.startsWith('2026-03'))
  .reduce((sum, e) => sum + num(e.data.cost), 0);

const activeRepos = repos.filter((r) => r.data.is_active === 'True').length;
const engProjects = projects.filter((p) => p.data.classification === 'engineering').length;
const activeTools = tools.filter((t) => t.data.status === 'confirmed_active').length;

const costDisplay = totalAwsCost > 0 ? `$${Math.round(totalAwsCost / 1000)}K` : '$383K';

const chartCount = readdirSync('../analysis/charts')
  .filter((f) => f.endsWith('.json') && !f.startsWith('_')).length;

const findings = [
  {
    title: '27.7% Epic Completion',
    detail: 'Only 1 in 4 planned initiatives were completed. Healthy engineering organizations finish 60\u201380% of planned epics per quarter. This means roadmap commitments to the business are unreliable.',
    severity: 'critical',
    chartSlug: 'jira_epic_completion',
  },
  {
    title: '89% Priority Inflation',
    detail: '89% of all work items are marked "High" priority. When everything is urgent, nothing is \u2014 teams cannot distinguish what actually matters first. The priority system needs a reset.',
    severity: 'critical',
  },
  {
    title: '0 Repos with Branch Protection',
    detail: 'No repositories have automated rules preventing code from being merged without review. This means any engineer can push directly to production without a second pair of eyes \u2014 a basic safety net is missing.',
    severity: 'critical',
    href: '/engineering',
    hrefLabel: 'Engineering',
  },
  {
    title: '60.7% Pipeline Success Rate',
    detail: '4 in 10 automated builds fail. Industry benchmark is above 95%. Every failed build means wasted engineering time debugging infrastructure instead of shipping product.',
    severity: 'warning',
    chartSlug: 'pipeline_health_gauge',
  },
  {
    title: '9% Story Point Coverage',
    detail: 'Only 9% of work items have effort estimates. Without estimation, the organization cannot predict when work will be done or how much capacity is available. Planning is guesswork.',
    severity: 'warning',
    href: '/delivery',
    hrefLabel: 'Delivery',
  },
  {
    title: 'Key Person Risk',
    detail: 'The top 3 at-risk individuals each handle over 35% of their team\u2019s code reviews. If any one of them leaves, their team loses the ability to review and ship code at its current pace.',
    severity: 'warning',
    chartSlug: 'key_person_risk',
  },
];

const sections = [
  {
    href: '/engagement',
    title: 'Engagement',
    desc: 'Charter, timeline, nine hypotheses with pre-evidence, post-reorg leadership, interview plan, and deliverables.',
    metric: '9',
    metricLabel: 'hypotheses',
  },
  {
    href: '/infrastructure',
    title: 'Infrastructure',
    desc: '18 AWS accounts, $383K/month. 83% pre-Graviton EC2, 90% ECS containers without health checks.',
    metric: costDisplay,
    metricLabel: 'monthly',
  },
  {
    href: '/engineering',
    title: 'Engineering',
    desc: '3,191 repos across 4 workspaces. 0 branch protection, 60.7% pipeline success, 201 stale PRs.',
    metric: fmt(repos.length),
    metricLabel: 'repos',
  },
  {
    href: '/delivery',
    title: 'Delivery',
    desc: '141 Jira projects. 27.7% epic completion, 89.4% priority inflation, 59-day cycle time P50.',
    metric: projects.length.toString(),
    metricLabel: 'projects',
  },
  {
    href: '/documentation',
    title: 'Documentation',
    desc: '14,111 Confluence pages indexed. RCA process gap since 2023, architecture docs fragmented across 5+ spaces.',
    metric: fmt(pages.length),
    metricLabel: 'pages',
  },
  {
    href: '/people',
    title: 'People & Org',
    desc: '499 individuals mapped across 5 systems. Key person risk, communication gaps, 39% inactive users with access.',
    metric: users.filter((u: any) => u.data.status !== 'bot').length.toString(),
    metricLabel: 'people',
  },
  {
    href: '/surveys',
    title: 'Surveys',
    desc: 'Five diagnostic instruments: DORA, Westrum Culture, DevEx, Pragmatic Engineer, AI Adoption & Tooling.',
    metric: '5',
    metricLabel: 'surveys',
  },
  {
    href: '/tooling',
    title: 'Tooling',
    desc: '28 tools cataloged. Dual CI/CD (Jenkins + Pipelines), self-hosted Grafana stack, utilization unknown.',
    metric: tools.length.toString(),
    metricLabel: 'tools',
  },
  {
    href: '/financial',
    title: 'Financial Intelligence',
    desc: '90-day cash flow analysis. Revenue by product, payments economics, $279K/mo committed cost cuts, and 6 key risks.',
    metric: '$35.6M',
    metricLabel: '2026 forecast',
  },
  {
    href: '/charts',
    title: 'Charts',
    desc: 'Interactive charts spanning infrastructure, engineering, delivery, people, and documentation.',
    metric: chartCount.toString(),
    metricLabel: 'charts',
  },
];
---

<BaseLayout title="Dashboard">
  <div class="mb-10">
    <h1 class="text-2xl font-bold text-[var(--text)]">
      Technology & Operations Review
    </h1>
    <p class="mt-2 text-sm text-[var(--text-secondary)] max-w-2xl">
      A three-week assessment of Mad Mobile's technology operations covering infrastructure, engineering practices, delivery health, documentation, tooling, and organizational dynamics. This dashboard surfaces the most critical findings. Each section links to detailed analysis with supporting data.
    </p>
  </div>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Key Findings</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-10">
    {findings.map((f) => (
      <FindingCard
        severity={f.severity === 'critical' ? 'red' : 'amber'}
        title={f.title}
        detail={f.detail}
        chartSlug={f.chartSlug}
        href={f.href}
        hrefLabel={f.hrefLabel}
      />
    ))}
  </div>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Visual Summary</h2>
  <div class="grid lg:grid-cols-2 gap-4 mb-10">
    <ChartEmbed
      slug="hypothesis_evidence_radar"
      title="Hypothesis Evidence Strength"
      caption="Nine hypotheses tested during the assessment. Spokes farther from center indicate stronger evidence. The three strongest findings -- portfolio sprawl, priority inflation, and key person risk -- are confirmed with quantitative data."
    />
    <ChartEmbed
      slug="pipeline_health_gauge"
      title="Pipeline Health"
      caption="Overall CI/CD pipeline success rate. The green zone starts at 95% -- the industry baseline for healthy delivery. At 60.7%, roughly 4 in 10 builds fail, which means engineering time is spent debugging infrastructure instead of shipping features."
    />
  </div>

  <dl class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
    <MetricCard label="AWS Monthly Spend" value={costDisplay} subtitle="March 2026 (18 accounts)" href="/infrastructure" />
    <MetricCard label="Repositories" value={fmt(repos.length)} subtitle={`${activeRepos} active`} href="/engineering" />
    <MetricCard label="Jira Projects" value={projects.length.toString()} subtitle={`${engProjects} engineering`} href="/delivery" />
    <MetricCard label="Confluence Pages" value={fmt(pages.length)} subtitle="Indexed in Confluence" href="/documentation" />
    <MetricCard label="Tools Identified" value={tools.length.toString()} subtitle={`${activeTools} confirmed active`} href="/tooling" />
  </dl>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4 mt-2">Deep Analysis</h2>
  <dl class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
    <MetricCard label="Epic Completion" value={`${epicData.overall_resolution_rate_pct}%`} subtitle={`${epicData.resolved} of ${epicData.total_epics} resolved`} benchmark="Healthy: 60\u201380%" href="/delivery" />
    <MetricCard label="Priority Inflation" value="89%" subtitle="of issues marked High" benchmark="Healthy: <30% High" href="/delivery" />
    <MetricCard label="Incidents Parsed" value={rcaData.total_incidents_parsed?.toString() ?? '50'} subtitle="Peak: 2022 (26)" href="/documentation" />
    <MetricCard label="ECS Health Checks" value={`${Math.round((ecsData.containers_without_health_check / ecsData.total_containers) * 100)}%`} subtitle="containers missing" benchmark="Target: 0% missing" href="/infrastructure" />
    <MetricCard label="Story Points" value={`${customFields.story_points_coverage?.coverage_pct ?? 9}%`} subtitle="stories estimated" benchmark="Healthy: >80%" href="/delivery" />
  </dl>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Explore</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {sections.map(({ href, title, desc, metric, metricLabel }) => (
      <a
        href={href}
        class="group bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5 hover:border-[var(--accent)] hover:shadow-sm transition-all"
      >
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-base font-semibold text-[var(--text)] group-hover:text-[var(--accent)] transition-colors">
            {title}
          </h3>
          <span class="text-lg font-mono font-semibold text-[var(--accent)] tabular-nums">{metric}</span>
        </div>
        <p class="text-xs text-[var(--text-secondary)]">{desc}</p>
        <p class="text-[10px] text-[var(--text-muted)] mt-1 uppercase tracking-wider">{metricLabel}</p>
      </a>
    ))}
  </div>
</BaseLayout>
