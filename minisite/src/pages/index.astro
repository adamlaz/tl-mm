---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import MetricCard from '../components/MetricCard.astro';
import { getCollection } from 'astro:content';
import { num, fmt } from '../lib/parse';
import { readFileSync } from 'node:fs';

const awsCosts = await getCollection('awsCosts');
const repos = await getCollection('bitbucketRepos');
const projects = await getCollection('jiraProjects');
const pages = await getCollection('confluencePages');
const tools = await getCollection('toolingCatalog');
let users: any[] = [];
try { users = await getCollection('peopleDirectory') as any; } catch {}
if (!users.length) { try { users = await getCollection('userAudit') as any; } catch {} }

const epicData = JSON.parse(readFileSync('../inventory/jira/epic_completion.json', 'utf-8'));
const rcaData = JSON.parse(readFileSync('../inventory/confluence/rca_timeline.json', 'utf-8'));
let reviewData = {};
try { reviewData = JSON.parse(readFileSync('../inventory/bitbucket/review_network_summary.json', 'utf-8')); } catch {}
const ecsData = JSON.parse(readFileSync('../inventory/aws/ecs_task_definitions.json', 'utf-8'));
const customFields = JSON.parse(readFileSync('../inventory/jira/custom_fields.json', 'utf-8'));

const totalAwsCost = awsCosts
  .filter((e) => e.data.month.startsWith('2026-03'))
  .reduce((sum, e) => sum + num(e.data.cost), 0);

const activeRepos = repos.filter((r) => r.data.is_active === 'True').length;
const engProjects = projects.filter((p) => p.data.classification === 'engineering').length;
const activeTools = tools.filter((t) => t.data.status === 'confirmed_active').length;

const costDisplay = totalAwsCost > 0 ? `$${Math.round(totalAwsCost / 1000)}K` : '$383K';

const findings = [
  { title: '27.7% Epic Completion', detail: 'Only 1 in 4 epics resolved — weak delivery follow-through', severity: 'warning' },
  { title: '89% Priority Inflation', detail: 'Nearly all issues marked High — priorities are meaningless', severity: 'critical' },
  { title: '0 Repos with Branch Protection', detail: 'No repositories have branch restrictions enabled', severity: 'critical' },
  { title: '60.7% Pipeline Success Rate', detail: '4 in 10 builds fail — CI/CD reliability is a drag on velocity', severity: 'warning' },
  { title: '9% Story Point Coverage', detail: 'Estimation is almost nonexistent — capacity planning impossible', severity: 'warning' },
  { title: 'Key Person Risk', detail: 'Top 3 risk people each handle >35% of their team code reviews — knowledge silos across Platform and Restaurant', severity: 'warning' },
];

const sections = [
  {
    href: '/engagement',
    title: 'Engagement',
    desc: 'Charter, timeline, nine hypotheses with pre-evidence, post-reorg leadership, interview plan, and deliverables.',
    metric: '9',
    metricLabel: 'hypotheses',
  },
  {
    href: '/infrastructure',
    title: 'Infrastructure',
    desc: 'Cost breakdown, resource counts, and runtime analysis across 18 AWS accounts.',
    metric: costDisplay,
    metricLabel: 'monthly',
  },
  {
    href: '/engineering',
    title: 'Engineering',
    desc: 'Source control health: repository activity, pull request speed, and build automation coverage.',
    metric: fmt(repos.length),
    metricLabel: 'repos',
  },
  {
    href: '/delivery',
    title: 'Delivery',
    desc: 'Sprint performance, time from start to done, scope changes, and work-type balance.',
    metric: projects.length.toString(),
    metricLabel: 'projects',
  },
  {
    href: '/documentation',
    title: 'Documentation',
    desc: 'Documentation volume, space activity, and content creation patterns.',
    metric: fmt(pages.length),
    metricLabel: 'pages',
  },
  {
    href: '/people',
    title: 'People & Org',
    desc: 'Organization structure, team intelligence, interaction networks, and key-person risk across 5 systems.',
    metric: users.filter((u: any) => u.data.status !== 'bot').length.toString(),
    metricLabel: 'people',
  },
  {
    href: '/surveys',
    title: 'Surveys',
    desc: 'Five team health surveys covering deployment maturity, culture, developer experience, engineering practices, and AI adoption.',
    metric: '5',
    metricLabel: 'surveys',
  },
  {
    href: '/tooling',
    title: 'Tooling',
    desc: 'Vendor and tool catalog across build pipelines, monitoring, security, and more.',
    metric: tools.length.toString(),
    metricLabel: 'tools',
  },
  {
    href: '/charts',
    title: 'Charts',
    desc: 'Interactive charts spanning infrastructure, engineering, delivery, and documentation.',
    metric: '39',
    metricLabel: 'charts',
  },
];
---

<BaseLayout title="Dashboard">
  <div class="mb-10">
    <h1 class="text-2xl font-bold text-[var(--text)]">
      Technology & Operations Review
    </h1>
    <p class="mt-2 text-sm text-[var(--text-secondary)] max-w-xl">
      A three-week technology and operations assessment of Mad Mobile's infrastructure,
      engineering practices, delivery health, documentation, and tooling.
    </p>
  </div>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Key Findings</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-10">
    {findings.map((f) => (
      <div class:list={[
        'border-l-4 bg-[var(--surface)] rounded-r-lg p-4',
        f.severity === 'critical' ? 'border-[var(--status-red)]' : 'border-[var(--status-amber)]',
      ]}>
        <p class="text-sm font-medium text-[var(--text)]">{f.title}</p>
        <p class="text-xs text-[var(--text-secondary)] mt-1">{f.detail}</p>
      </div>
    ))}
  </div>

  <dl class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
    <MetricCard label="AWS Monthly Spend" value={costDisplay} subtitle="March 2026 (18 accounts)" />
    <MetricCard label="Repositories" value={fmt(repos.length)} subtitle={`${activeRepos} active`} />
    <MetricCard label="Jira Projects" value={projects.length.toString()} subtitle={`${engProjects} engineering`} />
    <MetricCard label="Confluence Pages" value={fmt(pages.length)} subtitle="In Confluence" />
    <MetricCard label="Tools Identified" value={tools.length.toString()} subtitle={`${activeTools} confirmed active`} />
  </dl>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4 mt-2">Deep Analysis</h2>
  <dl class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
    <MetricCard label="Epic Completion" value={`${epicData.overall_resolution_rate_pct}%`} subtitle={`${epicData.resolved} of ${epicData.total_epics} resolved`} />
    <MetricCard label="Priority Inflation" value="89%" subtitle="of issues marked High" />
    <MetricCard label="Incidents Parsed" value={rcaData.total_incidents_parsed?.toString() ?? '50'} subtitle="Peak: 2022 (26)" />
    <MetricCard label="ECS Health Checks" value={`${Math.round((ecsData.containers_without_health_check / ecsData.total_containers) * 100)}%`} subtitle="containers missing" />
    <MetricCard label="Story Points" value={`${customFields.story_points_coverage?.coverage_pct ?? 9}%`} subtitle="stories estimated" />
  </dl>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Explore</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {sections.map(({ href, title, desc, metric, metricLabel }) => (
      <a
        href={href}
        class="group bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5 hover:border-[var(--accent)] hover:shadow-sm transition-all"
      >
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-base font-semibold text-[var(--text)] group-hover:text-[var(--accent)] transition-colors">
            {title}
          </h3>
          <span class="text-lg font-mono font-semibold text-[var(--accent)] tabular-nums">{metric}</span>
        </div>
        <p class="text-xs text-[var(--text-secondary)]">{desc}</p>
        <p class="text-[10px] text-[var(--text-muted)] mt-1 uppercase tracking-wider">{metricLabel}</p>
      </a>
    ))}
  </div>
</BaseLayout>
