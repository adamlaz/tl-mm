---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MetricCard from '../components/MetricCard.astro';
import FindingCard from '../components/FindingCard.astro';
import MilestoneStep from '../components/MilestoneStep.astro';
import TabulatorGrid from '../components/TabulatorGrid.astro';

const surveys = [
  { name: 'DORA Quick Check', questions: 9, time: '~3 min', audience: 'Leads, Managers', measures: 'Deploy frequency, lead time, change failure rate, recovery time, reliability' },
  { name: 'Westrum Culture', questions: 7, time: '~2 min', audience: 'Leads, Managers, Sr ICs, PMs', measures: 'Information flow, psychological safety, collaboration, failure response' },
  { name: 'DevEx (DX Core 4)', questions: 23, time: '~7 min', audience: 'All ICs (engineers, QE, designers)', measures: 'Speed, Effectiveness, Quality, Impact (18 core + 5 MM-specific context)' },
  { name: 'Pragmatic Engineer Test', questions: 15, time: '~3 min', audience: 'Leads, Sr Engineers', measures: '12 yes/no engineering maturity practices + context' },
  { name: 'AI Tooling & Adoption', questions: 20, time: '~5 min', audience: 'All Eng, Product, Design, QE', measures: 'AI adoption maturity, strategy clarity, tooling health' },
];

const totalQuestions = surveys.reduce((s, v) => s + v.questions, 0);

const matrix = [
  { role: 'Engineering Manager / Lead', dora: '✓', westrum: '✓', devex: '', pragmatic: '✓', ai: '✓' },
  { role: 'Senior IC / Staff Engineer', dora: '', westrum: '✓', devex: '✓', pragmatic: '✓', ai: '✓' },
  { role: 'Software Engineer', dora: '', westrum: '✓', devex: '✓', pragmatic: '', ai: '✓' },
  { role: 'QE Engineer', dora: '', westrum: '✓', devex: '✓', pragmatic: '', ai: '✓' },
  { role: 'Product Manager', dora: '', westrum: '✓', devex: '', pragmatic: '', ai: '✓' },
  { role: 'Product Designer', dora: '', westrum: '✓', devex: '', pragmatic: '', ai: '✓' },
];

const timeline = [
  { date: 'Apr 1–3', milestone: 'Survey instruments finalized, reviewed, Forms built' },
  { date: 'Apr 6', milestone: 'Deployed — Chathura sent to 57 recipients (engineering, product, QE, design, cross-functional)' },
  { date: 'Apr 7', milestone: '~13 responses received (~23% response rate). Monitoring.' },
  { date: 'Apr 10', milestone: '38 responses received (67%). Surveys closed.' },
  { date: 'Apr 11', milestone: 'Pre-onsite analysis: score, segment, identify themes' },
  { date: 'Apr 13–15', milestone: 'Onsite: use survey results to guide interview probes' },
];

const doraCrosswalk = [
  { metric: 'Deployment Frequency', selfReport: 'DORA Q1', systemData: 'Bitbucket deploy tags, release branches' },
  { metric: 'Lead Time for Changes', selfReport: 'DORA Q2', systemData: 'PR cycle time (bitbucket_pr_metrics.csv)' },
  { metric: 'Change Failure Rate', selfReport: 'DORA Q3', systemData: 'Jira bugs created / deploys ratio' },
  { metric: 'Time to Restore', selfReport: 'DORA Q4', systemData: 'Grafana MTTR, CloudWatch (if accessible)' },
  { metric: 'Reliability', selfReport: 'DORA Q5', systemData: 'CloudWatch alarms (access pending)' },
];

const surveyDetails = [
  {
    name: 'DORA Quick Check',
    source: 'dora.dev/quickcheck',
    scoring: '4-tier benchmark: Elite / High / Medium / Low for each of 5 core metrics',
    key: 'Compare self-reported vs. actual system data for calibration gaps',
  },
  {
    name: 'Westrum Culture',
    source: 'Westrum organizational typology',
    scoring: 'Average 1–5 Likert: 1.0–2.4 Pathological, 2.5–3.4 Bureaucratic, 3.5–5.0 Generative',
    key: 'Segment by team and tenure to detect biz-tech mistranslation (Hypothesis H)',
  },
  {
    name: 'DevEx (DX Core 4)',
    source: 'DX Core 4 framework + MM-specific questions',
    scoring: 'Four dimensions: Speed, Effectiveness, Quality, Impact — each scored from constituent questions',
    key: 'Q19–Q23 add Bitbucket workspace, Jira count, priority changes, backlog confidence, CI/CD system',
  },
  {
    name: 'Pragmatic Engineer Test',
    source: 'Gergely Orosz (pragmaticengineer.com)',
    scoring: '12 yes/no: 11–12 mature, 8–10 solid, 5–7 gaps, 0–4 urgent. Context questions for frustration mapping.',
    key: 'Identifies which specific engineering practices are missing or inconsistent across teams',
  },
  {
    name: 'AI Tooling & Adoption',
    source: 'Custom for this engagement',
    scoring: '3 dimensions: AI Adoption Maturity (Q1–6), AI Strategy Clarity (Q7, Q12–13), Tooling Health (Q8–11). 20 questions total.',
    key: 'Q7 vs Q12 gap = strategy credibility problem. Segment CAKE vs Retail vs Neo vs Payments.',
  },
];

const exploreCards = [
  { href: '/surveys/dora', title: 'DORA Quick Check', desc: '9 questions, ~3 min. Deploy frequency, lead time, change failure rate, recovery time.', metric: '9', metricLabel: 'questions', formsUrl: 'https://forms.cloud.microsoft/Pages/DesignPageV2.aspx?origin=RevampFRE&subpage=design&id=ib_aDhNew0Kr1vaH6f4POuzhwTnhYKxDp5P7TQtHDhRUQU9JNFJJMzg2R1dGUlhWRTYwODc1UURaVi4u' },
  { href: '/surveys/culture', title: 'Westrum Culture', desc: '7 questions, ~2 min. Organizational culture type: pathological, bureaucratic, or generative.', metric: '7', metricLabel: 'questions', formsUrl: 'https://forms.cloud.microsoft/Pages/DesignPageV2.aspx?origin=RevampFRE&subpage=design&id=ib_aDhNew0Kr1vaH6f4POuzhwTnhYKxDp5P7TQtHDhRURjJXR01JU0Q5Tk8xSFNKUVFWMEIxQ1FSMC4u' },
  { href: '/surveys/devex', title: 'Developer Experience', desc: '23 questions, ~7 min. Feedback loops, cognitive load, flow state, satisfaction (DX Core 4).', metric: '23', metricLabel: 'questions', formsUrl: 'https://forms.cloud.microsoft/r/021mP98Sf9' },
  { href: '/surveys/engineering', title: 'Pragmatic Engineer Test', desc: '15 questions, ~3 min. 12 yes/no engineering culture maturity checks + 3 context.', metric: '15', metricLabel: 'questions', formsUrl: 'https://forms.cloud.microsoft/Pages/DesignPageV2.aspx?origin=RevampFRE&subpage=design&id=ib_aDhNew0Kr1vaH6f4POuzhwTnhYKxDp5P7TQtHDhRUNUtQWVRMWlZQRExUME1LMjNJM1lER0xaTC4u' },
  { href: '/surveys/ai-tooling', title: 'AI Adoption & Tooling', desc: '20 questions, ~5 min. AI adoption, tooling landscape, strategy clarity.', metric: '20', metricLabel: 'questions', formsUrl: 'https://forms.cloud.microsoft/Pages/DesignPageV2.aspx?origin=RevampFRE&subpage=design&id=ib_aDhNew0Kr1vaH6f4POuzhwTnhYKxDp5P7TQtHDhRUMDNHRTNRU05KRTdRWDJWTE41UFZEMkUxNi4u' },
];

const milestones = [
  { date: 'Apr 1-3', title: 'Survey instruments finalized', detail: 'All 5 instruments reviewed, question sets locked, scoring guides prepared.', status: 'complete' as const },
  { date: 'Apr 4', title: 'DevEx draft live in Microsoft Forms', detail: 'First survey built. Link: forms.cloud.microsoft/r/021mP98Sf9', status: 'complete' as const },
  { date: 'Apr 5', title: 'All 5 surveys built in Microsoft Forms', detail: 'DORA (9q), Westrum (7q), Pragmatic Engineer (15q), AI Adoption & Tooling (20q) built. DevEx (23q) was already live. All links ready for distribution.', status: 'complete' as const },
  { date: 'Apr 5', title: 'AI Adoption & Tooling — confirmed by Chathura', detail: "Survey 5 link sent to Chathura and confirmed for inclusion. All 5 surveys deployed.", status: 'complete' as const },
  { date: 'Apr 6', title: 'Chathura sends intro as CDO', detail: 'Survey links distributed to all engineering, product, design, and QE via Chathura\'s intro email.', status: 'complete' as const },
  { date: 'Apr 10', title: '38 responses received — surveys closed', detail: '67% response rate (38 of 57). Well above minimum threshold for usable survey data.', status: 'active' as const },
  { date: 'Apr 10-12', title: 'Pre-onsite analysis', detail: 'Score all instruments, segment by team/product area, identify top patterns, build interview questions. Final prep Sunday evening.', status: 'active' as const },
];
---

<BaseLayout title="Surveys">
  <SectionHeader
    eyebrow="SURVEYS"
    title="Five Diagnostic Instruments"
    description="Five diagnostic survey instruments designed to measure how the organization works today. Each survey uses an industry-standard framework to establish a quantitative baseline that Mad Mobile can re-measure at 30 and 60 days to track real improvement. All responses are anonymous -- only aggregate patterns are reported."
  />

  <div class="grid sm:grid-cols-2 gap-4 mb-8">
    <FindingCard
      severity="green"
      title="All 5 Surveys Deployed — Chathura Confirmed"
      detail="All 5 surveys deployed to 57 recipients via Chathura's CDO intro email. AI Adoption & Tooling (Survey 5) confirmed and included. 38 responses received (67%) by April 10 deadline."
      status="Confirmed"
    />
    <FindingCard
      severity="green"
      title="Designed for Independent Re-Use"
      detail="All 5 instruments designed so Mad Mobile can re-run at 30/60 days without TL involvement. Baseline scores established pre-onsite. Includes scoring templates and comparison guidance."
    />
  </div>

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Surveys" value="5" subtitle={`${totalQuestions} total questions`} />
    <MetricCard label="Recipients" value="57" subtitle="Sent by Chathura Apr 6" />
    <MetricCard label="Responses" value="38" subtitle="67% rate. Closed Apr 10" />
    <MetricCard label="Platform" value="MS Forms" subtitle="On MM account" />
  </dl>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Deployment Timeline</h2>
    {milestones.map((m, i) => (
      <MilestoneStep
        date={m.date}
        title={m.title}
        detail={m.detail}
        status={m.status}
        last={i === milestones.length - 1}
      />
    ))}
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Survey Summary</h2>
    <TabulatorGrid
      columns={[
        { key: 'name', label: 'Survey', sortable: true },
        { key: 'questions', label: 'Questions', align: 'right', sortable: true, type: 'number' },
        { key: 'time', label: 'Time', sortable: true },
        { key: 'audience', label: 'Audience', sortable: true, type: 'badge' },
        { key: 'measures', label: 'Measures', sortable: true },
      ]}
      rows={surveys}
    />
  </div>

  <div class="mb-10">
    <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Who Takes What</h2>
    <TabulatorGrid
      columns={[
        { key: 'role', label: 'Role', sortable: true, type: 'badge' },
        { key: 'dora', label: 'DORA', sortable: true, type: 'boolean' },
        { key: 'westrum', label: 'Westrum', sortable: true, type: 'boolean' },
        { key: 'devex', label: 'DevEx', sortable: true, type: 'boolean' },
        { key: 'pragmatic', label: 'Pragmatic', sortable: true, type: 'boolean' },
        { key: 'ai', label: 'AI Tooling', sortable: true, type: 'boolean' },
      ]}
      rows={matrix.map(r => ({
        ...r,
        dora: r.dora === '✓' ? 'Yes' : 'No',
        westrum: r.westrum === '✓' ? 'Yes' : 'No',
        devex: r.devex === '✓' ? 'Yes' : 'No',
        pragmatic: r.pragmatic === '✓' ? 'Yes' : 'No',
        ai: r.ai === '✓' ? 'Yes' : 'No',
      }))}
    />
  </div>

  <div class="grid lg:grid-cols-2 gap-6 mb-10">
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">DORA Crosswalk</h2>
      <TabulatorGrid
        columns={[
          { key: 'metric', label: 'Metric', sortable: true, minWidth: '160px' },
          { key: 'selfReport', label: 'Self-Report', sortable: true, minWidth: '120px' },
          { key: 'systemData', label: 'System Data Source', sortable: true, minWidth: '200px' },
        ]}
        rows={doraCrosswalk}
      />
    </div>
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Deployment Timeline</h2>
      <TabulatorGrid
        columns={[
          { key: 'date', label: 'Date', sortable: true },
          { key: 'milestone', label: 'Milestone', sortable: true },
        ]}
        rows={timeline}
      />
    </div>
  </div>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Survey Instruments</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {exploreCards.map((card) => (
        <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5 hover:border-[var(--accent)] transition-colors">
          <div class="flex items-start justify-between gap-3 mb-2">
            <a href={card.href} class="group">
              <h3 class="text-sm font-semibold text-[var(--text)] group-hover:text-[var(--accent)] transition-colors">{card.title}</h3>
            </a>
            <span class="shrink-0 text-2xl font-mono font-semibold text-[var(--accent)] tabular-nums leading-none">{card.metric}</span>
          </div>
          <p class="text-[13px] text-[var(--text-secondary)] leading-relaxed mb-3">{card.desc}</p>
          <div class="flex items-center justify-between">
            <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--text-muted)]">{card.metricLabel}</span>
            <a href={card.formsUrl} target="_blank" rel="noopener noreferrer" class="text-[10px] font-medium uppercase tracking-wider text-[var(--accent)] hover:underline">MS Forms &rarr;</a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="mb-10">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Deployment Message Template</h2>
    <div class="bg-[var(--surface)] border-l-[3px] border-l-[var(--accent)] rounded-xl p-5">
      <p class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-3">Subject: Quick surveys ahead of our technology review</p>
      <div class="text-[13px] text-[var(--text-secondary)] leading-relaxed space-y-3">
        <p>Team,</p>
        <p>As part of my onboarding as Co-CEO, I've asked Adam Lazarus to help me get a clear picture of how our technology and delivery systems work. Adam has deep experience translating between business and engineering, and he'll be onsite April 13–15.</p>
        <p>Before he arrives, I'd like everyone in engineering and product to complete a short set of surveys. These take under 15 minutes total and are completely anonymous.</p>
        <p>The surveys measure things like deployment speed, team culture, and developer experience using industry-standard benchmarks. The goal isn't to evaluate anyone — it's to understand where the system helps or hinders your ability to do great work.</p>
        <p>Your honest answers matter. Please complete by April 10.</p>
        <p>Thanks,<br />Don</p>
      </div>
    </div>
    <p class="text-xs text-[var(--text-muted)] mt-3 leading-relaxed">Note: Chathura finalized his own version of this message. All 5 surveys confirmed and deployed April 6. 38 responses received by deadline (67% of 57 recipients).</p>
  </div>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Survey Details</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {surveyDetails.map((s) => (
      <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-5">
        <h3 class="text-sm font-semibold text-[var(--text)] mb-2">{s.name}</h3>
        <dl class="space-y-2 text-xs">
          <div>
            <dt class="text-[var(--text-muted)] uppercase tracking-wider">Source</dt>
            <dd class="text-[var(--text-secondary)]">{s.source}</dd>
          </div>
          <div>
            <dt class="text-[var(--text-muted)] uppercase tracking-wider">Scoring</dt>
            <dd class="text-[var(--text-secondary)]">{s.scoring}</dd>
          </div>
          <div>
            <dt class="text-[var(--text-muted)] uppercase tracking-wider">Key Signal</dt>
            <dd class="text-[var(--text-secondary)]">{s.key}</dd>
          </div>
        </dl>
      </div>
    ))}
  </div>
</BaseLayout>
