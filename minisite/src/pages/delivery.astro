---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MetricCard from '../components/MetricCard.astro';
import TabulatorGrid from '../components/TabulatorGrid.astro';
import ChartEmbed from '../components/ChartEmbed.astro';
import FindingCard from '../components/FindingCard.astro';
import { getCollection } from 'astro:content';
import { num, fmt } from '../lib/parse';
import { jiraProjectUrl } from '../lib/links';
import { readFileSync } from 'node:fs';

let epicData: any = {};
let priorityData: any = {};
let blockingData: any = {};
let statusData: any = {};
let workflowData: any = {};
let rootCauseData: any = {};
let customFieldData: any = {};
try { epicData = JSON.parse(readFileSync('../inventory/jira/epic_completion.json', 'utf-8')); } catch {}
try { priorityData = JSON.parse(readFileSync('../inventory/jira/priority_distribution.json', 'utf-8')); } catch {}
try { blockingData = JSON.parse(readFileSync('../inventory/jira/blocking_chains.json', 'utf-8')); } catch {}
try { statusData = JSON.parse(readFileSync('../inventory/jira/status_transitions.json', 'utf-8')); } catch {}
try { workflowData = JSON.parse(readFileSync('../inventory/jira/workflows.json', 'utf-8')); } catch {}
try { rootCauseData = JSON.parse(readFileSync('../inventory/jira/root_cause_distribution.json', 'utf-8')); } catch {}
try { customFieldData = JSON.parse(readFileSync('../inventory/jira/custom_fields.json', 'utf-8')); } catch {}

const epicResRate = epicData.overall_resolution_rate_pct ?? 0;
const priorityDist = (priorityData.distribution ?? []) as Array<{priority: string; count: number; pct_of_sample: number}>;
const highPct = priorityDist.find((d: any) => d.priority === 'High')?.pct_of_sample ?? 89;

const projects = await getCollection('jiraProjects');
const velocity = await getCollection('jiraVelocity');
const cycleTime = await getCollection('jiraCycleTime');

const engProjects = projects.filter((p) => p.data.classification === 'engineering');
const totalIssues = projects.reduce((s, p) => s + num(p.data.issue_count), 0);

const avgCompletion =
  velocity.length > 0 ? velocity.reduce((s, v) => s + num(v.data.completion_rate), 0) / velocity.length : 0;

const resolvedCycleEntries = cycleTime.filter((c) => num(c.data.cycle_time_days) > 0);
const medianCycle = (() => {
  if (resolvedCycleEntries.length === 0) return 0;
  const sorted = resolvedCycleEntries.map((c) => num(c.data.cycle_time_days)).sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 !== 0 ? sorted[mid]! : (sorted[mid - 1]! + sorted[mid]!) / 2;
})();

const byClassification = new Map<string, { count: number; issues: number }>();
for (const p of projects) {
  const cls = p.data.classification || 'unclassified';
  const prev = byClassification.get(cls) ?? { count: 0, issues: 0 };
  byClassification.set(cls, { count: prev.count + 1, issues: prev.issues + num(p.data.issue_count) });
}

const classRows = [...byClassification.entries()]
  .sort((a, b) => b[1].issues - a[1].issues)
  .map(([cls, { count, issues }]) => ({
    classification: cls,
    projects: count,
    issues: fmt(issues),
  }));

const velocityRows = velocity
  .sort((a, b) => b.data.start_date.localeCompare(a.data.start_date))
  .slice(0, 50)
  .map((v) => ({
    board: v.data.board,
    sprint: v.data.sprint,
    done: v.data.done_issues,
    total: v.data.total_issues,
    rate: `${num(v.data.completion_rate).toFixed(1)}%`,
  }));

/* --- Workflow Analysis data --- */
const statuses = workflowData.statuses ?? {};
const totalStatuses = statuses.total ?? 0;
const customStatusCount = statuses.custom_count ?? 0;
const builtinStatusCount = statuses.builtin_count ?? 0;
const byCategory = statuses.by_category ?? {};
const categoryRows = Object.entries(byCategory)
  .sort((a: any, b: any) => (b[1] as number) - (a[1] as number))
  .map(([cat, count]) => ({
    category: cat,
    count: count as number,
    pct: `${((count as number) / totalStatuses * 100).toFixed(0)}%`,
  }));

const statusDurations = (statusData.status_durations ?? []) as Array<{status: string; sample_count: number; median_hours: number; median_days: number}>;
const bottleneck = statusData.bottleneck ?? {};
const durationRows = statusDurations
  .sort((a, b) => b.sample_count - a.sample_count)
  .map((d) => ({
    status: d.status,
    samples: d.sample_count,
    median_hrs: d.median_hours.toFixed(1),
    median_days: d.median_days.toFixed(1),
  }));

/* --- Root Cause Analysis data --- */
const rcFieldName = rootCauseData.field_name ?? 'Root Cause Category';
const rcBugsSampled = rootCauseData.total_bugs_sampled ?? 0;
const rcPopulated = rootCauseData.populated_count ?? 0;
const rcPopRate = rootCauseData.population_rate_pct ?? 0;
const rcDistribution = rootCauseData.distribution ?? {};
const rcDistRows = Object.entries(rcDistribution)
  .sort((a: any, b: any) => (b[1] as number) - (a[1] as number))
  .map(([cause, count]) => ({
    cause,
    count: count as number,
    pct: rcBugsSampled > 0 ? `${((count as number) / rcBugsSampled * 100).toFixed(1)}%` : '0%',
  }));

/* --- Custom Fields data --- */
const totalCustomFields = customFieldData.total_custom_fields ?? 0;
const spCoverage = customFieldData.story_points_coverage ?? {};
const spCoveragePct = spCoverage.coverage_pct ?? 0;
const spSampled = spCoverage.total_stories_sampled ?? 0;
const spWithPoints = spCoverage.with_points ?? 0;
const interestingFields = (customFieldData.interesting_fields ?? []) as Array<{id: string; name: string; type: string; custom_type: string}>;

const fieldTypeMap = new Map<string, number>();
for (const f of interestingFields) {
  const t = f.type;
  fieldTypeMap.set(t, (fieldTypeMap.get(t) ?? 0) + 1);
}
const fieldTypeRows = [...fieldTypeMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([type, count]) => ({ type, count }));

const rcRelatedFields = interestingFields.filter((f) =>
  f.name.toLowerCase().includes('root cause') || f.name.toLowerCase().includes('rca')
);
const rcFieldRows = rcRelatedFields.map((f) => ({
  name: f.name,
  id: f.id,
  type: f.type,
}));

const charts = [
  { slug: 'jira_org_overview', title: 'Org Overview' },
  { slug: 'jira_velocity_trend', title: 'Velocity Trend' },
  { slug: 'jira_cycle_time', title: 'Cycle Time' },
  { slug: 'jira_scope_change', title: 'Scope Change' },
  { slug: 'jira_assignee_load', title: 'Assignee Load' },
  { slug: 'jira_backlog_age', title: 'Backlog Age' },
  { slug: 'jira_flow_distribution', title: 'Flow Distribution' },
  { slug: 'jira_flow_distribution_engineering', title: 'Flow Distribution (Engineering)' },
  { slug: 'jira_created_vs_resolved', title: 'Created vs Resolved' },
  { slug: 'jira_issue_distribution', title: 'Issue Distribution' },
  { slug: 'jira_issue_distribution_engineering', title: 'Issue Distribution (Engineering)' },
  { slug: 'jira_issue_distribution_overall', title: 'Issue Distribution (Overall)' },
];
---

<BaseLayout title="Delivery">
  <SectionHeader eyebrow="DELIVERY" title="Delivery" description={`Jira delivery health across ${projects.length} projects. Data extracted April 3–4, 2026 (V7).`} />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <FindingCard severity="red" title="27.7% Epic Completion" detail="481 engineering epics in 12 months, only 133 resolved. REST: 18.5%. NEO: 12.5%." evidence="481 total, 133 resolved" href="/engagement/hypotheses" hrefLabel="Hypothesis A" />
    <FindingCard severity="red" title="89.4% Priority Inflation" detail="Nearly every open issue marked High. No other levels in use. Priority is meaningless as a triage signal." evidence="89.4% High, 10.6% None" />
    <FindingCard severity="amber" title="59-Day Cycle Time (P50)" detail="Engineering-only, In Progress to Done. P75 = 210 days. P95 = 233 days." evidence="P50: 59d, P75: 210d, P95: 233d" />
    <FindingCard severity="amber" title="9% Story Point Coverage" detail="Story Points populated on only 27 of 300 sampled stories. Capacity planning impossible." evidence="9% coverage, 27/300 stories" />
    <FindingCard severity="amber" title="0% Root Cause Category" detail="Jira field exists but populated on 0% of resolved bugs. Process documented in Confluence but not enforced." evidence="customfield_10382: 0% populated" />
  </div>

  <div class="grid lg:grid-cols-2 gap-6 mb-10">
    <ChartEmbed slug="jira_epic_completion" title="Epic Completion" />
    <ChartEmbed slug="jira_priority_inflation" title="Priority Inflation" />
  </div>

  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard
      label="Jira Projects"
      value={projects.length.toString()}
      subtitle={`${engProjects.length} engineering`}
    />
    <MetricCard label="Total Issues" value={fmt(totalIssues)} />
    <MetricCard label="Sprint Completion" value={`${avgCompletion.toFixed(1)}%`} subtitle="Average across sprints" />
    <MetricCard label="Median Cycle Time" value={`${medianCycle.toFixed(1)}d`} subtitle="Days to resolve" />
  </dl>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4 mt-2">Deep Analysis</h2>
  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Epic Completion" value={`${epicResRate}%`} subtitle={`${epicData.resolved ?? 0} of ${epicData.total_epics ?? 0} epics resolved (12mo)`} />
    <MetricCard label="Priority Inflation" value={`${highPct}%`} subtitle="of open issues are 'High'" />
    <MetricCard label="Blocking Issues" value={(blockingData.issues_blocked ?? 0).toString()} subtitle={`${blockingData.issues_blocking_others ?? 0} blocking others`} />
    <MetricCard label="Story Points Coverage" value={`${spCoveragePct}%`} subtitle={`${spWithPoints} of ${spSampled} stories have estimates`} />
  </dl>

  <div class="grid lg:grid-cols-2 gap-6 mb-8">
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Priority Distribution</h2>
      <TabulatorGrid
        columns={[
          { key: 'priority', label: 'Priority', sortable: true, type: 'badge', badgeMap: { Highest: 'red', High: 'amber', Medium: 'muted', Low: 'green', Lowest: 'green' } },
          { key: 'count', label: 'Count', align: 'right', sortable: true, type: 'number' },
          { key: 'pct', label: '%', align: 'right', sortable: true, type: 'bar', barMax: 100 },
        ]}
        rows={priorityDist.map((d: any) => ({ priority: d.priority, count: d.count, pct: `${d.pct_of_sample}%` }))}
      />
    </div>
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Top Epics by Project</h2>
      <TabulatorGrid
        columns={[
          { key: 'project', label: 'Project', sortable: true },
          { key: 'total', label: 'Epics', align: 'right', sortable: true, type: 'number' },
          { key: 'resolved', label: 'Resolved', align: 'right', sortable: true, type: 'number' },
          { key: 'rate', label: 'Rate', align: 'right', sortable: true, type: 'bar', barMax: 100 },
        ]}
        rows={(epicData.top_10_by_count ?? []).map((e: any) => ({ project: e.project, _href_project: jiraProjectUrl(e.project), total: e.total_epics, resolved: e.resolved, rate: `${e.resolution_rate_pct}%` }))}
      />
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6 mb-8">
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Projects by Classification</h2>
      <TabulatorGrid
        columns={[
          { key: 'classification', label: 'Classification', sortable: true, type: 'badge' },
          { key: 'projects', label: 'Projects', align: 'right', sortable: true, type: 'number' },
          { key: 'issues', label: 'Issues', align: 'right', sortable: true },
        ]}
        rows={classRows}
      />
    </div>
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Recent Sprints</h2>
      <TabulatorGrid
        columns={[
          { key: 'board', label: 'Board', sortable: true, filterable: true },
          { key: 'sprint', label: 'Sprint', sortable: true },
          { key: 'done', label: 'Done', align: 'right', sortable: true, type: 'number' },
          { key: 'total', label: 'Total', align: 'right', sortable: true, type: 'number' },
          { key: 'rate', label: 'Rate', align: 'right', sortable: true, type: 'bar', barMax: 100, bottomCalc: 'avg' },
        ]}
        rows={velocityRows}
        groupBy="board"
        searchable
        exportable
        pageSize={25}
      />
    </div>
  </div>

  <!-- Workflow Analysis -->
  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4 mt-2">Workflow Analysis</h2>
  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Total Statuses" value={totalStatuses.toString()} subtitle={`${customStatusCount} custom, ${builtinStatusCount} built-in`} />
    <MetricCard label="In Progress Statuses" value={(byCategory['In Progress'] ?? 0).toString()} subtitle={`${((byCategory['In Progress'] ?? 0) / totalStatuses * 100).toFixed(0)}% of all statuses`} />
    <MetricCard label="Issues Analyzed" value={(statusData.issues_analyzed ?? 0).toString()} subtitle="Transition sample set" />
    <MetricCard label="Bottleneck" value={bottleneck.status ?? 'N/A'} subtitle={bottleneck.median_days ? `${bottleneck.median_days}d median wait` : ''} />
  </dl>

  <div class="grid lg:grid-cols-2 gap-6 mb-8">
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Status Categories</h2>
      <TabulatorGrid
        columns={[
          { key: 'category', label: 'Category', sortable: true, type: 'badge' },
          { key: 'count', label: 'Statuses', align: 'right', sortable: true, type: 'number' },
          { key: 'pct', label: '%', align: 'right', sortable: true },
        ]}
        rows={categoryRows}
      />
    </div>
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Status Duration Analysis</h2>
      <TabulatorGrid
        columns={[
          { key: 'status', label: 'Status', sortable: true },
          { key: 'samples', label: 'Samples', align: 'right', sortable: true, type: 'number' },
          { key: 'median_hrs', label: 'Median Hrs', align: 'right', sortable: true, type: 'heat', heatMax: 500 },
          { key: 'median_days', label: 'Median Days', align: 'right', sortable: true, type: 'number' },
        ]}
        rows={durationRows}
        searchable
        exportable
        pageSize={10}
      />
    </div>
  </div>

  <!-- Root Cause Analysis -->
  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4 mt-2">Root Cause Analysis</h2>
  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Bugs Sampled" value={rcBugsSampled.toString()} subtitle="Bug issues checked for RCA" />
    <MetricCard label="RCA Population" value={`${rcPopRate}%`} subtitle={`${rcPopulated} of ${rcBugsSampled} have a root cause`} />
    <MetricCard label="RCA Field" value={rcFieldName} subtitle={`Field: ${rootCauseData.field_id ?? 'N/A'}`} />
    <MetricCard label="RCA-Related Fields" value={rcRelatedFields.length.toString()} subtitle="Custom fields for root cause tracking" />
  </dl>

  <div class="grid lg:grid-cols-2 gap-6 mb-8">
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Root Cause Distribution</h2>
      <TabulatorGrid
        columns={[
          { key: 'cause', label: 'Category', sortable: true, type: 'badge' },
          { key: 'count', label: 'Count', align: 'right', sortable: true, type: 'number' },
          { key: 'pct', label: '%', align: 'right', sortable: true },
        ]}
        rows={rcDistRows}
      />
      {rcPopRate === 0 && (
        <p class="mt-3 text-xs text-[var(--text-muted)] bg-[var(--surface)] border border-[var(--border)] rounded-lg px-4 py-3">
          <strong>Gap:</strong> The root cause category field is unpopulated across all {rcBugsSampled} sampled bugs.
          Establishing an RCA discipline would improve defect prevention.
        </p>
      )}
    </div>
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Root Cause Custom Fields</h2>
      <TabulatorGrid
        columns={[
          { key: 'name', label: 'Field Name', sortable: true },
          { key: 'id', label: 'Field ID' },
          { key: 'type', label: 'Type', sortable: true },
        ]}
        rows={rcFieldRows}
      />
      <p class="mt-3 text-xs text-[var(--text-muted)] bg-[var(--surface)] border border-[var(--border)] rounded-lg px-4 py-3">
        Multiple root-cause-related fields exist ({rcRelatedFields.length} total), suggesting fragmented categorization across projects.
      </p>
    </div>
  </div>

  <!-- Estimation & Custom Fields -->
  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4 mt-2">Estimation & Custom Fields</h2>
  <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <MetricCard label="Custom Fields" value={totalCustomFields.toString()} subtitle="Total Jira custom fields" />
    <MetricCard label="Story Points Coverage" value={`${spCoveragePct}%`} subtitle={`${spWithPoints} of ${spSampled} sampled stories`} />
    <MetricCard label="Notable Fields" value={interestingFields.length.toString()} subtitle="Fields relevant to delivery analysis" />
    <MetricCard label="Field Types" value={fieldTypeRows.length.toString()} subtitle="Distinct data types in use" />
  </dl>

  <div class="grid lg:grid-cols-2 gap-6 mb-8">
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Field Type Distribution</h2>
      <TabulatorGrid
        columns={[
          { key: 'type', label: 'Field Type', sortable: true },
          { key: 'count', label: 'Count', align: 'right', sortable: true, type: 'number' },
        ]}
        rows={fieldTypeRows}
      />
    </div>
    <div>
      <h2 class="text-sm font-semibold text-[var(--text-secondary)] mb-3">Notable Custom Fields</h2>
      <TabulatorGrid
        columns={[
          { key: 'name', label: 'Field Name', sortable: true },
          { key: 'type', label: 'Type', sortable: true, filterable: true },
          { key: 'id', label: 'Field ID' },
        ]}
        rows={interestingFields.map((f) => ({ name: f.name, type: f.type, id: f.id }))}
        searchable
        exportable
        pageSize={10}
      />
    </div>
  </div>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">Full Project Directory</h2>
  <p class="text-sm text-[var(--text-secondary)] mb-4">
    All {projects.length} Jira projects. Filter by classification, category, or lead to navigate the portfolio.
  </p>

  <div class="mb-10">
    <TabulatorGrid
      columns={[
        { key: 'key', label: 'Key', sortable: true },
        { key: 'name', label: 'Name', sortable: true },
        { key: 'lead', label: 'Lead', sortable: true },
        { key: 'category', label: 'Category', sortable: true, filterable: true, type: 'badge' },
        { key: 'classification', label: 'Classification', sortable: true, filterable: true, type: 'badge' },
        { key: 'issues', label: 'Issues', align: 'right', sortable: true, type: 'number' },
      ]}
      rows={projects.map((p: any) => ({
        key: p.data.key,
        _href_key: jiraProjectUrl(p.data.key),
        name: p.data.name,
        lead: p.data.lead || '',
        category: p.data.category || '',
        classification: p.data.classification || 'unclassified',
        issues: num(p.data.issue_count),
      }))}
      searchable
      exportable
      pageSize={25}
      groupBy="classification"
    />
  </div>

  <div class="bg-[var(--surface)] rounded-xl border border-[var(--border)] p-4 flex items-center justify-between mb-8">
    <div>
      <p class="text-sm font-medium text-[var(--text)]">People directory with team and manager context</p>
      <p class="text-xs text-[var(--text-secondary)]">See org chart positions, team assignments, and cross-system activity for all assignees.</p>
    </div>
    <a href="/people/directory" class="px-3 py-1.5 text-xs font-medium text-[var(--accent)] border border-[var(--accent)] rounded-lg hover:bg-[var(--accent-subtle)] transition-colors flex-shrink-0">People &rarr; Directory</a>
  </div>

  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-4">Charts</h2>
  <div class="grid lg:grid-cols-2 gap-6">
    {charts.map((c) => (
      <ChartEmbed slug={c.slug} title={c.title} />
    ))}
  </div>

  <div class="mt-10 pt-6 border-t border-[var(--border-subtle)]">
    <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] mb-3">Related</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <FindingCard severity="red" title="83% Pre-Graviton EC2" detail="Infrastructure debt constrains delivery velocity — 167 of 201 instances on legacy hardware." href="/infrastructure" hrefLabel="Infrastructure" />
      <FindingCard severity="red" title="0 Repos with Branch Protection" detail="No required approvals or build checks — code quality issues flow directly to delivery." href="/engineering" hrefLabel="Engineering" />
    </div>
  </div>
</BaseLayout>
