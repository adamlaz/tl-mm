---
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="en" class="bg-surface">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Mad Mobile Engagement</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body class="min-h-screen font-sans text-slate-800 antialiased">
    <div class="flex min-h-screen">
      <Sidebar currentPath={currentPath} />
      <div class="flex-1 flex flex-col min-w-0">
        <header class="border-b border-slate-200 bg-white px-6 py-3 flex items-center justify-between flex-shrink-0">
          <div class="flex items-center gap-3">
            <span class="text-sm font-semibold text-slate-900">Mad Mobile</span>
            <span class="text-slate-300">|</span>
            <span class="text-sm text-slate-500">Technology & Operations Review</span>
          </div>
          <span class="text-xs text-slate-400">April 2026</span>
        </header>
        <main class="flex-1 p-6 lg:p-8 pb-20 lg:pb-8" transition:animate="fade">
          <slot />
        </main>
        <footer class="border-t border-slate-200 bg-white px-6 py-3 text-xs text-slate-400 flex items-center justify-between flex-shrink-0">
          <span>Prepared by Translation Layer LLC</span>
          <span>Confidential</span>
        </footer>
      </div>
    </div>
  </body>
</html>
